// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  billing — Invoice + Payment (Slice 2a: fondasi persist)                     ║
// ║                                                                              ║
// ║  Prinsip: CHARGE = PROYEKSI order klinis (TIDAK disimpan di billing.*).       ║
// ║  Invoice = header + nomor + adjustment level-invoice; total/sisa DIHITUNG     ║
// ║  saat baca (proyeksi total − Σ payment). Payment = catatan bayar (dalam shift ║
// ║  kasir = SATU pintu). Soft-ref kunjunganId (validasi di Service, tanpa FK     ║
// ║  lintas-schema — pola inventory). Nomor via BillingCounter (INV/KW).          ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Counter nomor dokumen billing — INV (invoice) · KW (kwitansi). Reset per bulan
// (periode "YYYYMM"). Atomik via upsert-increment (pola inv_counter / master.*Counter).
model BillingCounter {
  kind    String // INV | KW
  periode String // "YYYYMM"
  lastSeq Int    @map("last_seq")

  @@id([kind, periode])
  @@map("billing_counter")
  @@schema("billing")
}

// Invoice — 1 per kunjungan (lazy-create saat bayar/buka detail). Header saja; charge
// tetap diproyeksikan dari order (Draft) / DIBEKUKAN ke InvoiceItem (Final). Adjustment
// level-invoice disiapkan (default 0).
//
// Lifecycle finalize (Slice 2f): status Draft → Final (bisa reopen balik ke Draft).
//   Draft = charge proyeksi HIDUP (recompute tiap baca).
//   Final = charge BEKU — snapshot baris ke billing.InvoiceItem; total/report otoritatif.
// Finalize = aksi BILLING (gate billing.invoice:update), BUKAN dipicu discharge klinis
// (charge sering menetes pasca-pulang). finalizedAt/By = stempel server (anti-spoof).
model Invoice {
  id          String @id @default(uuid(7)) @db.Uuid
  kunjunganId String @unique @map("kunjungan_id") @db.Uuid // soft-ref encounter.Kunjungan
  noInvoice   String @unique @map("no_invoice")            // "INV/YYYY/MM/NNNNN"

  // Adjustment level-invoice (dipakai Slice 2d) — nominal Rp.
  diskonInvoice Int     @default(0) @map("diskon_invoice")
  materai       Int     @default(0)
  ppnPct        Int     @default(0) @map("ppn_pct")
  catatan       String?

  // Lifecycle finalize (Slice 2f) — "Draft" | "Final".
  status            String    @default("Draft")
  finalizedAt       DateTime? @map("finalized_at") @db.Timestamptz(3)
  finalizedBy       String?   @map("finalized_by") // nama actor (server-resolved)
  finalizedByUserId String?   @map("finalized_by_user_id") @db.Uuid

  createdBy    String? @map("created_by") // nama actor (snapshot)
  authorUserId String? @map("author_user_id") @db.Uuid
  version      Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  payments    Payment[]
  items       InvoiceItem[]
  adjustments ItemAdjustment[]

  @@index([status])
  @@map("invoice")
  @@schema("billing")
}

// ItemAdjustment — penyesuaian per BARIS charge (overlay proyeksi, Slice 2d Fase 2). Charge =
// proyeksi order (read-only), jadi diskon/void per baris disimpan terpisah & di-cocokkan via
// `sourceRef` saat baca. `reduksi` = Rp aktual yang dikurangi (dihitung saat set, dari gross
// baris) → dipakai SERAGAM oleh detail (net per baris) & board (Σ reduksi) agar tak drift.
// 1 penyesuaian aktif per (invoice, sourceRef) — upsert; hapus = kembalikan gross. Diblokir Final.
model ItemAdjustment {
  id        String  @id @default(uuid(7)) @db.Uuid
  invoiceId String  @map("invoice_id") @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  sourceRef String  @map("source_ref")   // kunci baris charge (tindakan:… / lab:… / akomodasi:…)
  jenis     String                        // "diskon" | "void"
  mode      String?                        // "rp" | "pct" (diskon)
  nilai     Int     @default(0)            // input user: Rp (rp) atau persen (pct)
  reduksi   Int     @default(0)            // Rp aktual dikurangi (snapshot saat set)
  alasan    String?

  actorNama   String? @map("actor_nama")
  actorUserId String? @map("actor_user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([invoiceId, sourceRef])
  @@index([invoiceId])
  @@map("item_adjustment")
  @@schema("billing")
}

// InvoiceItem — SNAPSHOT baris charge saat finalize (beku). Ditulis dari proyeksi order
// (billingProjectionService) di dalam tx finalize; dihapus saat reopen. Draft = TIDAK ada baris
// (charge tetap proyeksi). Report periode meng-agregasi tabel ini (SUM per kategori/unit) via SQL.
model InvoiceItem {
  id        String  @id @default(uuid(7)) @db.Uuid
  invoiceId String  @map("invoice_id") @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  tanggal     DateTime @db.Timestamptz(3)            // waktu order/tindakan (atau hari akomodasi)
  nama        String
  sourceModul String   @map("source_modul")          // IGD | RI | RJ | Farmasi | Lab | Rad | Akomodasi | Adjustment
  sourceRef   String   @map("source_ref")            // dedupe key snapshot (tindakan:… / akomodasi:…)
  kategori    String                                  // Akomodasi | Administrasi | Tindakan | Lab | Rad | Obat & BMHP | Jasa Dokter | Lain-lain
  qty         Int
  satuan      String
  hargaSatuan Int      @map("harga_satuan")
  coverage    String                                  // Penjamin | Pasien | Mixed
  untariffed  Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([invoiceId])
  @@index([kategori])
  @@map("invoice_item")
  @@schema("billing")
}

// Shift kasir — sesi buka/tutup counter (persist Slice 2e). SATU pintu bayar: setiap
// Payment.shiftId (soft-ref TEXT) menunjuk shift ini. Totals TIDAK live di-simpan —
// diproyeksikan dari billing.payment saat baca (open) & DI-SNAPSHOT saat tutup (closed).
// Owner sesi = authorUserId (persistensi "shift saya" lintas navigasi). Operator =
// kasirPegawaiId (dipilih dari user role Kasir), kasirNama di-resolve server (anti-spoof).
model Shift {
  id             String  @id @default(uuid(7)) @db.Uuid
  counter        String // Kasir-1 | Kasir-2 | Kasir-3 | Kasir-IGD
  kasirNama      String  @map("kasir_nama") // snapshot nama operator (server-resolved dari pegawai)
  kasirPegawaiId String? @map("kasir_pegawai_id") @db.Uuid // operator (user role Kasir)
  authorUserId   String? @map("author_user_id") @db.Uuid // pemilik sesi (yang buka shift)

  status        String  @default("Open") // Open | Closed
  bukaAt        DateTime @map("buka_at") @db.Timestamptz(3)
  bukaSaldoAwal Int      @map("buka_saldo_awal")
  bukaCatatan   String?  @map("buka_catatan")

  // Snapshot saat TUTUP (open → totals live dari payment). breakdown per metode = JSONB.
  totalByMetode  Json? @map("total_by_metode")
  totalTransaksi Int   @default(0) @map("total_transaksi")
  totalRefund    Int   @default(0) @map("total_refund")

  // Tutup (Closed only)
  tutupAt         DateTime? @map("tutup_at") @db.Timestamptz(3)
  tutupSaldoAkhir Int?      @map("tutup_saldo_akhir")
  selisih         Int?
  tutupCatatan    String?   @map("tutup_catatan")
  supervisor      String?

  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([status])
  @@index([authorUserId, status])
  @@map("shift")
  @@schema("billing")
}

// AuditLog — jejak IMMUTABLE mutasi finansial invoice (UU PDP 27/2022, retensi ≥5 thn).
// Soft-ref invoiceId + kunjunganId (TANPA FK → audit bertahan walau invoice terhapus). Ditulis
// dalam tx aksi (finalize/reopen/adjustment/payment/void/create). `action` = AuditActionKind
// (invoice.finalize · invoice.reopen · invoice.diskon · payment.add/refund/void · invoice.create).
// `meta` JSONB simpan diff (before/after) + target. Aktor = server-resolved (anti-spoof).
model AuditLog {
  id          String  @id @default(uuid(7)) @db.Uuid
  invoiceId   String  @map("invoice_id") @db.Uuid    // soft-ref billing.Invoice
  kunjunganId String  @map("kunjungan_id") @db.Uuid  // soft-ref encounter.Kunjungan (kunci baca detail)
  action      String                                  // AuditActionKind
  actorNama   String  @map("actor_nama")              // nama pegawai (server-resolved)
  actorRole   String? @map("actor_role")              // peran utama actor (roles[0])
  actorUserId String? @map("actor_user_id") @db.Uuid
  summary     String                                  // ringkasan satu-baris
  amount      Int?                                     // nominal terkait (aksi keuangan)
  reason      String?                                 // alasan (reopen/void/diskon)
  noKwitansi  String? @map("no_kwitansi")             // referensi kwitansi (payment)
  meta        Json?                                    // { diff?: [...], target?: {...} }

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([invoiceId])
  @@index([kunjunganId])
  @@map("audit_log")
  @@schema("billing")
}

// Payment — 1 transaksi kas terhadap invoice. Metode/kategori = TEXT (FE-facing,
// validasi Zod). Void bukan delete (audit). nominal: + pembayaran/deposit, − refund.
model Payment {
  id        String  @id @default(uuid(7)) @db.Uuid
  invoiceId String  @map("invoice_id") @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  noKwitansi String @unique @map("no_kwitansi") // "KW/YYYY/MM/NNNNN"
  metode     String // Tunai | Transfer | QRIS | EDC | Voucher
  kategori   String @default("Pembayaran") // Pembayaran | Deposit | Refund
  nominal    Int
  kasir      String // nama kasir (server-resolved dari actor, anti-spoof)

  authorUserId String? @map("author_user_id") @db.Uuid
  shiftId      String? @map("shift_id") // referensi shift kasir (diikat Slice 2b)
  source       String? // Quick | Detail (provenance)
  bank         String?
  noRef        String? @map("no_ref")
  bukti        String?
  catatan      String?
  refundOf     String? @map("refund_of") @db.Uuid

  voided     Boolean   @default(false)
  voidReason String?   @map("void_reason")
  voidedBy   String?   @map("voided_by")
  voidedAt   DateTime? @map("voided_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([invoiceId])
  @@map("payment")
  @@schema("billing")
}
