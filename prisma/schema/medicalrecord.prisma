// ══════════════════════════════════════════════════════════════════════════════
//  ASESMEN MEDIS · sub-menu ALERGI — MODEL PER-ITEM (FHIR AllergyIntolerance-aligned).
//  Berbeda dari pane asesmen lain (yang point-in-time snapshot): alergi = DAFTAR HIDUP.
//  1 baris `Alergi` = 1 alergen dengan siklus hidup sendiri. Tambah = INSERT; "hapus" =
//  soft-delete (deletedAt) bukan hard-delete (jejak medico-legal). MUTABLE (version utk
//  koreksi nanti), bukan append-only → tulis hanya yang berubah (delta), tak foto-ulang
//  seluruh daftar tiap simpan. Per-kunjungan (key kunjunganId) untuk sekarang.
//  Mirror AllergyEntry (AsesmenMedisTab > AllergyPane). Vocab = String + divalidasi Zod.
// ══════════════════════════════════════════════════════════════════════════════

model AsesmenAlergi {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Identitas alergen (mirror AllergyEntry) ──
  category  String // Obat/Makanan/Lainnya
  allergen  String
  reactions String[] // jenis reaksi (Anafilaksis/Urtikaria/…)
  severity  String // Ringan/Sedang/Berat
  status    String // verifikasi: Terkonfirmasi/Dicurigai

  keterangan String?
  snomedCode String? @map("snomed_code")
  bzaKode    String? @map("bza_kode") // kode BZA (zat aktif KFA) bila allergen dipilih dari Katalog Obat → pelinkan resep

  // ── Pencatat + author (dari actor) ──
  pemeriksa       String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  // ── Audit (mutable: version + updatedAt; soft-delete medico-legal) ──
  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, deletedAt]) // daftar alergi aktif per kunjungan
  @@map("asesmen_alergi")
  @@schema("medicalrecord")
}

// ── Asesmen Alergi NKA (header per-kunjungan) — assertion "No Known Allergy" ──
//  1 baris per kunjungan (upsert di tempat). NKA & daftar alergi aktif saling eksklusif
//  (divalidasi Service). Tanpa header = belum diasesmen (NKA dianggap false).
model AsesmenAlergiNka {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @unique @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  nka Boolean @default(false) // No Known Allergy — tak ada riwayat alergi diketahui

  pemeriksa       String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("asesmen_alergi_nka")
  @@schema("medicalrecord")
}

// ── Skrining Gizi (MUST — Malnutrition Universal Screening Tool) ───────────────
//  Point-in-time screening (AP 1.3): append-only time-series — BANYAK baris/kunjungan
//  (skrining berkala, riwayat). latest by createdAt = skrining terkini. Mirror GiziHistoryEntry
//  + GiziState (GiziPane). Hanya 3 skor sumber disimpan; total & tingkat risiko = DERIVED
//  (dihitung Service/FE, tak disimpan — hindari drift, prinsip sama Observation NEWS2).
model AsesmenGizi {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Skor MUST (0/1/2 per komponen) ──
  skorBmi  Int @map("skor_bmi")  // BMI
  skorBb   Int @map("skor_bb")   // penurunan berat badan
  skorAkut Int @map("skor_akut") // efek penyakit akut (0 atau 2)

  // ── Tindak lanjut ──
  ahliGizi String? @map("ahli_gizi") // dirujuk ke ahli gizi / "Tidak dirujuk"
  catatan  String? // rencana intervensi gizi
  tanggal  String? // tanggal skrining (input FE date; savedAt = createdAt)

  // ── Petugas + author (dari actor) ──
  petugas         String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  // ── Audit (append-only: tanpa updatedAt/soft-delete; version utk konsistensi) ──
  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt]) // riwayat skrining per kunjungan (terbaru dulu)
  @@map("asesmen_gizi")
  @@schema("medicalrecord")
}

// ══════════════════════════════════════════════════════════════════════════════
//  ASESMEN MEDIS · sub-menu EDUKASI (HPK 2) — 3 sub-pane: Pasien & Keluarga ·
//  Emergency · End of Life. Tiap sub-pane = domain/tabel sendiri (prefix asesmen_edukasi_).
// ══════════════════════════════════════════════════════════════════════════════

// ── Edukasi Pasien & Keluarga ─────────────────────────────────────────────────
//  Log edukasi: append-only time-series — BANYAK baris/kunjungan (tiap sesi edukasi =
//  1 catatan). Mirror EduPKEntry + form PasienKeluargaPane (EdukasiPane.tsx). Field
//  terstruktur disimpan utuh (medico-legal); FE menyusun teks penerima/waktu utk tampilan.
model AsesmenEdukasiPasien {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Penerima edukasi ──
  penerima     String  // Pasien/Keluarga/Wali
  namaPenerima String? @map("nama_penerima") // bila Keluarga/Wali
  hubungan     String? // hubungan dgn pasien

  // ── Materi & metode ──
  topik           String[] // topik edukasi (≥1)
  media           String[] // media yang digunakan
  metode          String? // metode penyampaian (tunggal)
  hambatan        String[] // hambatan komunikasi
  catatanHambatan String?  @map("catatan_hambatan")

  // ── Evaluasi ──
  pemahaman           String  // paham/perlu_ulang/tidak_paham
  rencanaTindakLanjut String? @map("rencana_tindak_lanjut") // bila perlu re-edukasi
  catatan             String?

  // ── Waktu edukasi (input FE; savedAt = createdAt) ──
  tanggal String? // date
  jam     String? // time (field FE `waktu`)

  // ── Petugas/edukator + author (dari actor) ──
  petugas         String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  // ── Audit (append-only + soft-delete medico-legal: hapus = entered-in-error) ──
  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt]) // riwayat edukasi per kunjungan (terbaru dulu)
  @@map("asesmen_edukasi_pasien")
  @@schema("medicalrecord")
}

// ── Edukasi Emergency (instruksi discharge / follow-up / emergency response) ───
//  Log: append-only + soft-delete (pola Pasien & Keluarga). Mirror EmergencyEntry + form
//  EmergencyPane (EdukasiPane.tsx). Field terstruktur disimpan utuh (FE susun waktu tampilan).
model AsesmenEdukasiEmergency {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  tipe      String // Instruksi Discharge / Follow-up / Emergency Response / …
  instruksi String // instruksi utama untuk pasien/keluarga

  instruksiObat String? @map("instruksi_obat")
  diet          String?
  aktivitas     String?

  tandaBahaya     String[] @map("tanda_bahaya") // kondisi → segera ke IGD
  followUpDate    String?  @map("follow_up_date")
  followUpLokasi  String?  @map("follow_up_lokasi")
  kontakEmergency String?  @map("kontak_emergency")
  catatan         String?

  // ── Petugas + author (dari actor) ──
  petugas         String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt])
  @@map("asesmen_edukasi_emergency")
  @@schema("medicalrecord")
}

// ── Edukasi End of Life — Advance Care Planning (rencana perawatan lanjutan) ───
//  Care plan = single-record "latest wins" (≈1 baris berlaku/kunjungan; koreksi = baris baru,
//  latest by createdAt). Mirror form EndOfLifePane (EdukasiPane.tsx). Family meeting = log
//  terpisah (per-item, tabel sendiri) → tak ikut di-snapshot tiap simpan plan.
model AsesmenEdukasiEol {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Status kode resusitasi ──
  codeStatus String  @map("code_status") // full_code/dnr/dnar/comfort_only
  alasanKode String? @map("alasan_kode")

  // ── Pengambil keputusan / wali ──
  pengambilKeputusan String  @map("pengambil_keputusan") // Pasien Sendiri / Keluarga / Komite Etik
  namaWali           String? @map("nama_wali")
  hubunganWali       String? @map("hubungan_wali")
  kontakWali         String? @map("kontak_wali")
  advanceDirective   Boolean @default(false) @map("advance_directive")

  // ── Preferensi terapi ──
  terapiDiinginkan String[] @map("terapi_diinginkan")
  terapiDitolak    String[] @map("terapi_ditolak")

  // ── Paliatif ──
  tujuanPerawatan    String? @map("tujuan_perawatan")
  gejalaDitangani    String? @map("gejala_ditangani")
  kebutuhanSpiritual String? @map("kebutuhan_spiritual")
  petugasPaliatif    String? @map("petugas_paliatif")

  // ── Detail order DNR ──
  tanggalDNR String? @map("tanggal_dnr")
  dokterDNR  String? @map("dokter_dnr")
  catatanDNR String? @map("catatan_dnr")

  // ── Petugas pencatat + author (dari actor) ──
  petugas         String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt])
  @@map("asesmen_edukasi_eol")
  @@schema("medicalrecord")
}

// ── Log Pertemuan Keluarga (family meeting) — per-item, soft-delete ────────────
//  Keyed langsung kunjunganId (independen dari versi care plan). Mirror FamilyMeeting.
model AsesmenEdukasiEolMeeting {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  tanggal   String?
  peserta   String
  topik     String
  keputusan String?

  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt])
  @@map("asesmen_edukasi_eol_meeting")
  @@schema("medicalrecord")
}

// ── Diagnosa (tab Diagnosa — koding ICD-10 per kunjungan) ─────────────────────
//  Daftar hidup per-item: tambah = INSERT, ubah tipe/status = UPDATE, hapus =
//  soft-delete (jejak medico-legal). Maks 1 baris tipe Utama aktif per kunjungan
//  + kode unik per kunjungan (partial unique index di SQL migration).
//  namaDiagnosis/kategori/inaCbg = SNAPSHOT dari master ICD saat dipilih.

model Diagnosa {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  kodeIcd10     String @map("kode_icd10")
  namaDiagnosis String @map("nama_diagnosis")
  tipe          String // Utama/Sekunder/Komplikasi/Komorbid (Zod; partial unique Utama)
  status        String // Pasti/Dicurigai/Diferensial (Zod)
  alasan        String?
  analisa       String?

  kategori String? // chapter/blok master ICD (snapshot)
  inaCbg   String? @map("ina_cbg")

  pemeriksa       String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, deletedAt])
  @@map("diagnosa")
  @@schema("medicalrecord")
}

// ── Prosedur ICD-9-CM (tab Diagnosa — koding tindakan/prosedur) ───────────────
//  Per-item, tambah/hapus saja (tanpa edit). Kode unik per kunjungan (partial
//  unique index di SQL migration). nama/kategori = snapshot master ICD.

model DiagnosaProsedur {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  kode     String
  nama     String
  kategori String
  catatan  String?

  pemeriksa       String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, deletedAt])
  @@map("diagnosa_prosedur")
  @@schema("medicalrecord")
}

// ── Tindakan Medis (tab Tindakan — prosedur/tindakan yang DILAKUKAN per kunjungan) ──────────
//  BEDA dari DiagnosaProsedur (koding ICD-9 utk klaim): ini pencatatan OPERASIONAL tindakan +
//  jumlah + biaya (snapshot tarif) → hilir Billing & Resume Medis. Per-item: tambah/ubah-jumlah/
//  hapus (soft-delete, jejak medico-legal). nama/kode/kategori/harga = SNAPSHOT dari master.Tindakan
//  + Tarif Matrix (mis. UMUM/IGD) saat dicatat — tarif bisa berubah → dibekukan di baris ini.

model TindakanMedis {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  tindakanId String? @map("tindakan_id") @db.Uuid // ref master.Tindakan (null = non-katalog)

  kode     String @default("") // ICD-9-CM snapshot (boleh kosong)
  nama     String
  kategori String // master TindakanKategori (snapshot)
  jumlah   Int    @default(1)

  // Biaya snapshot (tarif bisa berubah → dibekukan saat dicatat)
  harga        Int?    // null = belum bertarif saat dicatat
  penjaminKode String? @map("penjamin_kode") // konteks tarif (mis. UMUM)
  jenisRuangan String? @map("jenis_ruangan") // konteks tarif (mis. IGD)

  pelaksana       String  // nama pelaksana (default user login, bisa override)
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  dilakukanPada DateTime  @default(now()) @map("dilakukan_pada") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, deletedAt])
  @@map("tindakan_medis")
  @@schema("medicalrecord")
}

// ── Resep (tab Resep Pasien — order obat ke depo/apotek Farmasi) ───────────────
//  1 ResepOrder = 1 lembar resep (header) → banyak ResepItem (baris obat). Order =
//  append-only (immutable setelah dibuat; koreksi = soft-delete + order baru). `status`
//  & `prioritas` MUTABLE → digerakkan workflow Farmasi (Menunggu→Ditelaah→…→Selesai).
//  Depo = snapshot kode+nama Location kategori "Farmasi" (master Unit & Ruangan).
//  Kondisi klinis (ginjal/menyusui/kehamilan) = snapshot decision-support saat resep ditulis.

model ResepOrder {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Tujuan depo Farmasi (snapshot Location) ──
  depoKode String? @map("depo_kode") // Location.kode kategori Farmasi
  depoNama String  @map("depo_nama") // nama depo (tampil)

  // ── Konteks klinis (snapshot) ──
  catatan          String?
  kondisiGinjal    String? @map("kondisi_ginjal")
  kondisiMenyusui  String? @map("kondisi_menyusui")
  kondisiKehamilan String? @map("kondisi_kehamilan")

  prioritas String @default("Rutin")    // CITO/Segera/Rutin
  status    String @default("Menunggu") // workflow Farmasi

  // ── Penulis resep (DPJP) snapshot ──
  penulis         String  // nama penulis resep
  penulisKontak   String? @map("penulis_kontak")
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  // ── TTE (Tanda Tangan Elektronik) — serial barcode + penanda tangan + waktu (mock always-success) ──
  tteToken    String?   @map("tte_token")     // serial yang di-encode jadi barcode di resep
  tteSignedBy String?   @map("tte_signed_by") // nama dokter penanda tangan (DPJP)
  tteSignedAt DateTime? @map("tte_signed_at") @db.Timestamptz(3)

  items   ResepItem[]
  telaahs ResepTelaah[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, deletedAt])
  @@index([depoKode, status])
  @@map("resep_order")
  @@schema("medicalrecord")
}

// ── Telaah / Pengkajian Resep (PMK 72/2016 · SatuSehat QuestionnaireResponse) ──────────
//  1 baris = 1 telaah resep oleh Apoteker. Append-only: telaah ulang = baris baru, latest by
//  createdAt = berlaku (selaras pola medicalrecord lain). Mengubah status order (Diterima →
//  Ditelaah | Dikembalikan) di transaksi milik Service. FHIR-ready: `answers` JSONB faithful
//  ke QuestionnaireResponse (grup administrasi/farmasetik/klinis → linkId→boolean), + ringkasan
//  lulus per-aspek (queryable) + keputusan + ekstra (substitusi/non-formularium/LASA = di luar
//  3 aspek PMK, kebijakan RS/SKP). Adapter emit QuestionnaireResponse = modul /ehis-fhir.

model ResepTelaah {
  id String @id @default(uuid(7)) @db.Uuid

  resepOrderId String     @map("resep_order_id") @db.Uuid
  order        ResepOrder @relation(fields: [resepOrderId], references: [id], onDelete: Cascade)
  kunjunganId  String     @map("kunjungan_id") @db.Uuid // denormalisasi (FHIR encounter ref)

  // ── Keputusan (queryable) ──
  hasil         String // Disetujui / Dikembalikan
  alasanKembali String? @map("alasan_kembali")
  catatan       String?

  // ── Ringkasan lulus per-aspek PMK (turunan answers, disimpan utk laporan) ──
  lulusAdministrasi Boolean @map("lulus_administrasi")
  lulusFarmasetik   Boolean @map("lulus_farmasetik")
  lulusKlinis       Boolean @map("lulus_klinis")

  // ── Jawaban faithful QuestionnaireResponse (linkId→bool per grup) + ekstra ──
  answers                   Json     @default("{}") // { administrasi:{}, farmasetik:{}, klinis:{} }
  substitusi                Json? // [{itemId, namaAsli, namaGenerik, alasan}]
  justifikasiNonFormularium Json?    @map("justifikasi_non_formularium") // {itemId: alasan}
  lasaKonfirmasi            Boolean? @map("lasa_konfirmasi")

  // ── Apoteker penelaah + author (dari actor) ──
  apoteker        String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([resepOrderId, createdAt])
  @@map("resep_telaah")
  @@schema("medicalrecord")
}

model ResepItem {
  id String @id @default(uuid(7)) @db.Uuid

  resepOrderId String     @map("resep_order_id") @db.Uuid
  order        ResepOrder @relation(fields: [resepOrderId], references: [id], onDelete: Cascade)

  kodeObat    String  @map("kode_obat")
  namaObat    String  @map("nama_obat")
  bzaKode     String? @map("bza_kode") // zat aktif KFA (bila obat dari Katalog) → pelinkan alergi
  dosis       String?
  dosisSekali String? @map("dosis_sekali")
  signa       String?
  jumlah      Int     @default(1)
  rute        String?
  aturanPakai String? @map("aturan_pakai")
  kategori    String  @default("Reguler") // Reguler/Narkotika/Psikotropika (snapshot)
  durasiHari  Int     @default(1) @map("durasi_hari")
  keterangan  String?
  isHAM       Boolean @default(false) @map("is_ham")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([resepOrderId])
  @@map("resep_item")
  @@schema("medicalrecord")
}

// ── Informed Consent (tab IC — persetujuan tindakan kedokteran, PMK 290/2008) ──
//  Daftar hidup per-item: 1 baris = 1 formulir persetujuan (per tindakan). Tambah = INSERT,
//  hapus = soft-delete (entered-in-error, jejak medico-legal). IMMUTABLE setelah dibuat
//  (tanpa update — koreksi = soft-delete + baris baru). Snapshot tindakan (nama/kategori) beku.
//  TTD pasien/wali disimpan langsung sebagai PNG data URL base64 (signatureData TEXT) — draw &
//  webcam dua-duanya; jangan ikut di-SELECT pada list (row bloat → DAL omit di list).

model InformedConsent {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  noFormulir String @map("no_formulir")

  // ── Tindakan (snapshot master.Tindakan saat dipilih; tindakanId nullable = ad-hoc/manual) ──
  tindakanId       String? @map("tindakan_id") @db.Uuid
  tindakanNama     String  @map("tindakan_nama")
  tindakanKategori String? @map("tindakan_kategori")

  // ── Penjelasan ──
  tujuan           String?
  manfaat          String?
  risiko           String[] // risiko tercentang
  risikoLain       String?  @map("risiko_lain")
  alternatif       String?
  konsekuensiTolak String?  @map("konsekuensi_tolak")
  pertanyaanPasien String?  @map("pertanyaan_pasien")

  // ── Keputusan ──
  keputusan   String  // setuju/menolak (Zod enum; field keputusan-kritis disimpan String — precedent sibling)
  alasanTolak String? @map("alasan_tolak")

  // ── Penanda tangan & saksi ──
  penandaHubungan String  @map("penanda_hubungan") // hubungan dgn pasien
  penandaNama     String  @map("penanda_nama")
  saksi1          String?
  saksi2          String?
  namaDokter      String  @map("nama_dokter") // DPJP/dokter pelaksana penjelas

  // ── TTD (PNG data URL base64; signatureData write-mostly, di-omit dari list) ──
  signatureMethod String?   @map("signature_method") // draw/webcam
  signatureData   String?   @map("signature_data")   // data URL base64 (TEXT)
  signedAt        DateTime? @map("signed_at") @db.Timestamptz(3)

  // ── Waktu persetujuan + author (dari actor) ──
  waktuPersetujuan DateTime @map("waktu_persetujuan") @db.Timestamptz(3)
  petugas          String   // nama denormalisasi pencatat (dari user login)
  authorUserId     String?  @map("author_user_id") @db.Uuid
  authorPegawaiId  String?  @map("author_pegawai_id") @db.Uuid

  // ── Audit (add/delete only — tanpa version/updatedAt; soft-delete medico-legal) ──
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, deletedAt])
  @@map("informed_consent")
  @@schema("medicalrecord")
}

// ── CPPT (Catatan Perkembangan Pasien Terintegrasi) ───────────────────────────
//  Daftar per-item lintas profesi (Dokter/Perawat/…), 1 baris = 1 catatan. Mirror
//  CPPTEntry (CPPTTab.tsx). Append-only secara klinis; mutable terbatas: koreksi isi
//  (edit), co-sign DPJP (verify), penanda tindak lanjut (flag), hapus = SOFT-DELETE
//  (entered-in-error, jejak medico-legal — RBAC clinical.cppt:delete, default Admin).
//
//  jenisCatatan = metode komunikasi efektif SKP 2:
//    SOAP → field naratif S/O/A/P + instruksi.
//    SBAR → S/O/A/P dipetakan ke Situation/Background/Assessment/Recommendation.
//    TBAK → instruksi verbal/telepon: `instruksi` + Tulis-Baca-Konfirmasi + pemberi;
//           wajib co-sign DPJP 1×24 jam (verified=false saat dibuat).
//  penulis/verifiedBy = nama denormalisasi dari actor (BUKAN free-text).

model Cppt {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Atribusi pencatat ──
  profesi String // Dokter/Perawat/Bidan/Apoteker/Gizi/Fisioterapi/Lainnya (Zod)
  penulis String // nama denormalisasi pencatat (dari user login)

  // ── Jenis & isi naratif ──
  jenisCatatan String  @map("jenis_catatan") @default("SOAP") // SOAP/SBAR/TBAK (Zod)
  subjektif    String?
  objektif     String?
  asesmen      String?
  planning     String?
  instruksi    String?

  // ── TBAK (instruksi verbal/telepon) ──
  tbakPemberi    String?  @map("tbak_pemberi")     // DPJP pemberi instruksi
  tbakMetode     String?  @map("tbak_metode")      // Telepon/Lisan (Zod)
  tbakTulis      Boolean? @map("tbak_tulis")        // langkah 1: dituliskan
  tbakBaca       Boolean? @map("tbak_baca")         // langkah 2: dibacakan ulang
  tbakKonfirmasi Boolean? @map("tbak_konfirmasi")   // langkah 3: dikonfirmasi pemberi

  // ── Verifikasi DPJP (co-sign) — null = tak perlu, false = menunggu, true = terverifikasi ──
  verified   Boolean?  // null bila catatan tak memerlukan co-sign
  verifiedBy String?   @map("verified_by") // nama DPJP verifikator (dari actor)
  verifiedAt DateTime? @map("verified_at") @db.Timestamptz(3)

  // ── Tindak lanjut ──
  flagged Boolean @default(false)

  // ── Waktu klinis + author (dari actor) ──
  waktuCatatan    DateTime @map("waktu_catatan") @db.Timestamptz(3)
  authorUserId    String?  @map("author_user_id") @db.Uuid
  authorPegawaiId String?  @map("author_pegawai_id") @db.Uuid

  // ── Audit (mutable terbatas: version + updatedAt; hapus = soft-delete medico-legal) ──
  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, waktuCatatan]) // riwayat per kunjungan (terbaru dulu)
  @@map("cppt")
  @@schema("medicalrecord")
}

// ── Rekonsiliasi Obat (tab Rekonsiliasi — medication reconciliation per fase transisi) ────────
//  Per fase transisi perawatan (admisi/transfer/discharge): append-only "latest wins" — tiap simpan
//  = parent baru + children obat snapshot; latest by createdAt PER fase = berlaku (form). RIWAYAT =
//  semua baris (lintas fase & versi, terbaru dulu). Pola parent+child = AsesmenObat+AsesmenObatItem.
//  SNARS PP 3.1 · SKP 3 · PMK 72/2016 (rekonsiliasi wajib tiap titik transisi). waktu = "Tanggal &
//  Waktu" form; petugas = nama user login (denormalisasi). obatList = baris obat (snapshot bebas —
//  bisa dari formularium ter-assign atau manual). isHAM = High-Alert (verifikasi ganda).

model Rekonsiliasi {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  fase    String  // admisi/transfer/discharge (Zod)
  selesai Boolean @default(false)
  catatan String?

  // ── Waktu klinis + petugas/author (dari actor) ──
  waktu           DateTime @db.Timestamptz(3) // "Tanggal & Waktu" rekonsiliasi
  petugas         String   // nama denormalisasi pencatat (dari user login)
  authorUserId    String?  @map("author_user_id") @db.Uuid
  authorPegawaiId String?  @map("author_pegawai_id") @db.Uuid

  // ── Audit (append-only: tanpa updatedAt/soft-delete; version utk konsistensi) ──
  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  obatList RekonsiliasiObat[]

  @@index([kunjunganId, createdAt]) // riwayat per kunjungan (terbaru dulu) + ambil latest per fase
  @@map("rekonsiliasi")
  @@schema("medicalrecord")
}

// ── Baris obat rekonsiliasi (snapshot saat simpan; urut `urutan`) ──────────────
model RekonsiliasiObat {
  id             String       @id @default(uuid(7)) @db.Uuid
  rekonsiliasiId String       @map("rekonsiliasi_id") @db.Uuid
  rekonsiliasi   Rekonsiliasi @relation(fields: [rekonsiliasiId], references: [id], onDelete: Cascade)

  namaObat    String  @map("nama_obat")
  dosis       String?
  rute        String?
  frekuensi   String?
  sumber      String? // Rumah/IGD/Rawat Jalan/Lain-lain
  keputusan   String  // Lanjut/Stop/Sesuaikan/Tunda (Zod)
  gantiDengan String? @map("ganti_dengan")
  alasan      String?
  isHAM       Boolean @default(false) @map("is_ham")

  urutan    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([rekonsiliasiId])
  @@map("rekonsiliasi_obat")
  @@schema("medicalrecord")
}

// ── Asuhan Keperawatan (tab Keperawatan — SDKI/SLKI/SIKI) ──────────────────────
//  1 baris = 1 diagnosa keperawatan (proses asuhan) per kunjungan. CRUD (edit, verify
//  co-sign, evaluasi shift, hapus=soft-delete) — mirror TindakanMedis. Template diisi
//  dari katalog master.Sdki (kodeSdki = soft-ref kode `D.NNNN`, snapshot saat dipilih).
//  Blok pengkajian (dataMayor/dataMinor) + intervensi (SIKI 4 kelompok) + evaluasi
//  (timeline shift) = JSONB. `kriteriaHasil` (SLKI) = text[]. tanggalInput = timestamptz
//  (DateTimePicker). perawat = denormalisasi dari actor (user login).

model AsuhanKeperawatan {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Diagnosa (SDKI; kodeSdki = soft-ref master.Sdki.kode, snapshot) ──
  kodeSdki     String @default("") @map("kode_sdki")
  diagnosa     String
  penyebab     String @default("")
  faktorResiko String @default("") @map("faktor_resiko")

  // ── Pengkajian (blok JSONB {subjektif, objektif}) ──
  dataMayor Json @map("data_mayor") @db.JsonB
  dataMinor Json @map("data_minor") @db.JsonB

  // ── Luaran SLKI ──
  tujuanDurasi  String   @default("") @map("tujuan_durasi")
  tujuanUnit    String   @default("Hari") @map("tujuan_unit") // Jam/Hari
  selama        String   @default("")
  kriteriaHasil String[] @map("kriteria_hasil")
  statusLuaran  String   @default("Dipantau") @map("status_luaran") // Teratasi/Teratasi_Sebagian/Belum_Teratasi/Dipantau

  // ── Intervensi SIKI (blok JSONB {observasi,terapeutik,edukasi,kolaborasi}) ──
  intervensi Json @db.JsonB

  // ── Evaluasi shift (timeline) — tabel anak AsuhanEvaluasi (bukan lagi JSONB) ──
  evaluasiShift AsuhanEvaluasi[]

  // ── Waktu + perawat/author (dari actor) ──
  tanggalInput    DateTime @map("tanggal_input") @db.Timestamptz(3)
  perawat         String   // nama denormalisasi pencatat (dari user login)
  authorUserId    String?  @map("author_user_id") @db.Uuid
  authorPegawaiId String?  @map("author_pegawai_id") @db.Uuid

  // ── Verifikasi (co-sign supervisor/DPJP) ──
  verified   Boolean   @default(false)
  verifiedBy String?   @map("verified_by")
  verifiedAt DateTime? @map("verified_at") @db.Timestamptz(3)

  // ── Status proses + audit (CRUD + soft-delete entered-in-error) ──
  aktif     Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, deletedAt])
  @@map("asuhan_keperawatan")
  @@schema("medicalrecord")
}

// ── Evaluasi Shift Asuhan Keperawatan (timeline SOAP per shift) ────────────────
//  1 baris = 1 catatan evaluasi pada satu titik waktu (per shift Pagi/Siang/Malam).
//  BANYAK baris per asuhan (monitoring berkala) — append-only time-series (medico-legal):
//  tambah = INSERT, tanpa edit/hapus (koreksi = baris baru). Anak dari AsuhanKeperawatan
//  (FK cascade). waktu = timestamptz (DateTimePicker global); perawat = denormalisasi
//  dari actor (user login). statusLuaran terakhir menetapkan status berjalan parent
//  (di-sync Service saat insert). Mirror EvaluasiShift (lib/data.ts) → zero-refactor.

model AsuhanEvaluasi {
  id String @id @default(uuid(7)) @db.Uuid

  asuhanId String            @map("asuhan_id") @db.Uuid
  asuhan   AsuhanKeperawatan @relation(fields: [asuhanId], references: [id], onDelete: Cascade)

  shift        String  // Pagi/Siang/Malam (Zod)
  subjektif    String? // keluhan pasien (boleh kosong)
  objektif     String  // temuan klinis / hasil pemeriksaan (wajib)
  statusLuaran String  @map("status_luaran") // Teratasi/Teratasi_Sebagian/Belum_Teratasi/Dipantau (Zod)

  // ── Waktu evaluasi (DateTimePicker) + perawat/author (dari actor) ──
  waktu           DateTime @db.Timestamptz(3)
  perawat         String   // nama denormalisasi pencatat (dari user login)
  authorUserId    String?  @map("author_user_id") @db.Uuid
  authorPegawaiId String?  @map("author_pegawai_id") @db.Uuid

  // ── Audit (append-only: tanpa updatedAt/soft-delete) ──
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([asuhanId, waktu]) // timeline per asuhan (urut kronologis)
  @@map("asuhan_evaluasi")
  @@schema("medicalrecord")
}

// ── Pemeriksaan Fisik (tab Pemeriksaan — status generalis + head-to-toe) ───────
//  Asesmen fisik point-in-time (SNARS AP 1). Append-only "latest wins" (mirip Anamnesis):
//  re-pemeriksaan = baris baru; latest by createdAt = berlaku. Shared lintas unit (IGD head-to-toe;
//  RI/RJ per-sistem menyusul) — di-key kunjunganId. Blok orientasi/sistem/bodyMarkings = JSONB;
//  temuanAbnormal (id preset) + temuanLain (manual) = text[]. waktuPemeriksaan = timestamptz
//  (DateTimePicker). dokterPemeriksa = roster ruangan (Select); perawat = sesi login (denormalisasi).
//  ku/kesadaran/gizi = vocab terkontrol (String, precedent); mobilitas opsional. Mirror PemeriksaanFisikEntry.

model PemeriksaanFisik {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Status generalis ──
  ku        String // Baik/Sedang/Berat (Zod)
  kesadaran String // Composmentis/Apatis/Delirium/Somnolen/Sopor/Koma (Zod)
  gizi      String // Baik/Kurang/Lebih/Obesitas (Zod)
  mobilitas String? // Mandiri/Dibantu/Tirah Baring (opsional)
  orientasi Json    @db.JsonB // {waktu,tempat,orang} boolean
  catatanGeneralis String? @map("catatan_generalis") // catatan generalis manual (opsional)

  // ── Pemeriksaan per region (head-to-toe IGD / per-sistem RI-RJ) — Record<key,string> ──
  sistem Json @db.JsonB

  // ── Temuan ──
  temuanAbnormal String[] @map("temuan_abnormal") // id preset checklist
  temuanLain     String[] @map("temuan_lain")     // temuan manual (free-text)
  catatanUmum    String?  @map("catatan_umum")

  // ── Penandaan area tubuh (forward-compat; {region,label,catatan}[]) ──
  bodyMarkings Json @default("[]") @map("body_markings") @db.JsonB

  // ── Waktu + pemeriksa/author (dari actor) ──
  waktuPemeriksaan DateTime @map("waktu_pemeriksaan") @db.Timestamptz(3)
  dokterPemeriksa  String   @map("dokter_pemeriksa") // nama denormalisasi (roster ruangan)
  perawat          String   // nama denormalisasi pencatat (dari user login)
  authorUserId     String?  @map("author_user_id") @db.Uuid
  authorPegawaiId  String?  @map("author_pegawai_id") @db.Uuid

  // ── Audit (append-only: tanpa updatedAt/soft-delete; version utk konsistensi) ──
  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt]) // ambil baris terbaru per kunjungan
  @@map("pemeriksaan_fisik")
  @@schema("medicalrecord")
}

// ── Penandaan Anatomi (tab Pemeriksaan, sub Anatomi — body-map per area) ────────
//  Daftar hidup per-item: 1 baris = 1 area tubuh yang ditandai (body diagram). Tambah =
//  INSERT (klik area), hapus = soft-delete (lepas tanda; jejak medico-legal), edit catatan =
//  UPDATE. Per kunjungan (key kunjunganId). region = id area (mis. "dada_kiri"); label =
//  snapshot nama tampil; catatan = temuan area. Mirror pola AsesmenAlergi (daftar hidup).
//  Gate clinical.pemeriksaan (satu tab Pemeriksaan). pemeriksa = denormalisasi sesi login.

model PenandaanAnatomi {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  region  String // id area tubuh (mis. "dada_kiri")
  label   String // nama tampil snapshot (mis. "Dada Kiri")
  catatan String @default("") // temuan/catatan area

  // ── Pencatat + author (dari actor) ──
  pemeriksa       String  // nama denormalisasi pencatat (dari user login)
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  // ── Audit (mutable terbatas: version + updatedAt; hapus = soft-delete medico-legal) ──
  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, deletedAt]) // daftar penanda aktif per kunjungan
