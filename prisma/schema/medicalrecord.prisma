// ── Penilaian Skala (sub-menu: Asesmen Risiko — generik, digerakkan master) ─────
//  SATU tabel untuk SEMUA skala risiko tervalidasi yang ditarik dari master
//  `master.SkalaInstrument` (Morse/Braden/Barthel/Humpty Dumpty/dst). Beda dengan sub-menu
//  bespoke (Fisik/Nyeri/Status/Pediatrik = field unik → tabel sendiri): skala skoring berbagi
//  satu bentuk (instrumen + jawaban + skor + interpretasi) → satu tabel snapshot.
//  Append-only time-series (riwayat per kunjungan; tiap simpan = baris baru). `skalaKode`/`skalaNama`
//  = SNAPSHOT denormalisasi master (bukan FK lintas-schema — instrumen bisa berubah/non-aktif,
//  hasil historis harus stabil). `jawaban` = JSONB [{itemId,itemLabel,score,optionLabel}].
//  Gate clinical.penilaian. Mirror SkalaRisikoPanel (PenilaianTab.tsx).

model PenilaianSkala {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Snapshot instrumen master (bukan FK; stabil walau master berubah) ──
  skalaKode String @map("skala_kode") // ref master.SkalaInstrument.kode (mis. SR-0002)
  skalaNama String @map("skala_nama") // denormalisasi (mis. "Morse Fall Scale")
  kategori  String @default("Risiko") // Risiko/Umum/Penyakit (ikut master)

  // ── Hasil skoring (snapshot) ──
  totalSkor         Int    @map("total_skor")
  totalMax          Int    @map("total_max")
  interpretasiLabel String @default("") @map("interpretasi_label") // mis. "Risiko Tinggi"
  interpretasiTone  String @default("") @map("interpretasi_tone")  // mis. "rose" (display)
  jawaban           Json   @default("[]") // [{itemId,itemLabel,score,optionLabel}]
  catatan           String @default("")   // addendum bebas

  // ── Pencatat + author (dari actor) ──
  pemeriksa       String  // nama denormalisasi pencatat (dari user login)
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  // ── Audit (append-only: tanpa updatedAt/soft-delete; version utk konsistensi) ──
  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt]) // riwayat per kunjungan (terbaru dulu)
  @@map("penilaian_skala")
  @@schema("medicalrecord")
}

// ── Penilaian Komposit (sub-menu: Jantung / Kanker — form spesifik-penyakit) ────
//  Asesmen spesialistik KOMPOSIT = narasi + vocab + KLASIFIKASI baku yg dikomposisi dari master
//  `master.SkalaInstrument` kategori Penyakit (Killip/NYHA/TIMI · ECOG/Grade/Stadium). Beda dgn
//  skala risiko murni (1 instrumen → penilaian_skala): di sini banyak field heterogen → disimpan
//  sebagai SNAPSHOT JSONB utuh (`data`), self-contained (stabil walau master berubah). Klasifikasi
//  TETAP dirender dari master saat input (definisi current), hasilnya ikut tersimpan di `data.skala`.
//  SATU tabel diskriminasi `jenis` (Jantung|Kanker) — envelope identik. Append-only.
//  Gate clinical.penilaian. Mirror JantungPanel/KankerPanel (PenilaianTab.tsx).

model PenilaianKomposit {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  jenis     String // "Jantung" | "Kanker"
  ringkasan String @default("") // kesimpulan ringkas (tampilan riwayat)
  data      Json   @default("{}") // snapshot form utuh: narasi + vocab + data.skala[] (hasil klasifikasi)

  // ── Pencatat + author (dari actor) ──
  pemeriksa       String  // nama denormalisasi pencatat (dari user login)
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  // ── Audit (append-only: tanpa updatedAt/soft-delete; version utk konsistensi) ──
  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([kunjunganId, jenis, createdAt]) // riwayat per kunjungan per jenis (terbaru dulu)
  @@map("penilaian_komposit")
  @@schema("medicalrecord")
}

// ══════════════════════════════════════════════════════════════════════════════
//  TAB PENANDAAN GAMBAR (status lokalis / body-diagram, IGD) — domain Outcome/Annotation.
//  Bagan = citra anatomi nyata per jenis kelamin (anterior) + odontogram FDI. Penanda =
//  Pin (titik) ATAU Draw (coretan area, jalur titik %) + keterangan + severitas. Daftar hidup
//  per-item: tambah = INSERT, hapus = soft-delete (jejak medico-legal); TANPA edit (koreksi =
//  hapus + baris baru, pola PemeriksaanPenunjang/InformedConsent). Koordinat % terhadap citra.
//  Gate clinical.pemeriksaan (body-map = dokumentasi pemeriksaan; selaras PenandaanAnatomi).
//  Mirror Anotasi FE (PenandaanGambarTab.tsx).

model PenandaanGambar {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  modelJenis String @map("model_jenis") // kanvas: pria | wanita | gigi
  kind       String                      // pin | draw
  koordinatX Float  @map("koordinat_x") // % anchor (titik pin / jangkar coretan)
  koordinatY Float  @map("koordinat_y")
  path       Json   @default("[]") // [{x,y}] jalur coretan (kind draw); [] utk pin
  region     String                      // regio anatomis terdeteksi (snapshot label)
  label      String
  deskripsi  String @default("")
  severitas  String                      // Normal | Ringan | Sedang | Berat | Trauma

  // ── Pencatat + author (dari actor) ──
  pemeriksa       String  // nama denormalisasi pencatat (dari user login)
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  // ── Audit (add/delete only — tanpa version/updatedAt; soft-delete medico-legal) ──
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, deletedAt]) // daftar penanda aktif per kunjungan
  @@map("penandaan_gambar")
  @@schema("medicalrecord")
}

// ══════════════════════════════════════════════════════════════════════════════
//  TAB SERAH TERIMA SHIFT (handover keperawatan SBAR, IGD/RI) — closed-loop.
//  Alur: perawat KELUAR (sesi login) menyusun catatan SBAR → perawat MASUK (sesi
//  berikutnya) menekan "Terima" → distempel penerima + waktu terima. Daftar hidup
//  per-item: tambah = INSERT, terima = UPDATE-stamp (sekali; pola verify co-sign
//  AsuhanKeperawatan), hapus = soft-delete (jejak medico-legal). 1 baris = 1 serah
//  terima (per tanggal × shift). tanggal/jam = string FE (DateTimePicker → split),
//  createdAt/receivedAt = anchor timestamptz medico-legal (precedent AsesmenEdukasi
//  tanggal/jam String). TTV TIDAK disimpan (single-source di Observation). SBAR = 4
//  field konsolidasi. Gate clinical.keperawatan (serah terima = aktivitas keperawatan;
//  Perawat penulis utama). Mirror HandoverEntry FE (HandoverTab.tsx).

model SerahTerima {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Konteks shift (FE-entered; tanggal/jam string, createdAt = anchor) ──
  tanggal        String // "YYYY-MM-DD" (tab tanggal)
  shift          String // Pagi/Siang/Malam (Zod)
  jamSerahTerima String @map("jam_serah_terima") // "HH:mm"

  // ── SBAR (1 field konsolidasi per huruf) ──
  situation      String
  background     String // tindakan & obat shift ini
  assessment     String
  recommendation String

  // ── Pemberi (penyusun = sesi login) + author ──
  perawatKeluar   String  @map("perawat_keluar") // nama denormalisasi
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  // ── Penerima (closed-loop "Terima") — "" = belum diterima ──
  perawatMasuk        String    @default("") @map("perawat_masuk") // nama denormalisasi penerima
  jamTerima           String?   @map("jam_terima") // "HH:mm" saat diterima
  receivedByUserId    String?   @map("received_by_user_id") @db.Uuid
  receivedByPegawaiId String?   @map("received_by_pegawai_id") @db.Uuid
  receivedAt          DateTime? @map("received_at") @db.Timestamptz(3)

  // ── Audit (create + receive-update + soft-delete medico-legal) ──
  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([kunjunganId, deletedAt]) // daftar serah terima aktif per kunjungan
  @@map("serah_terima")
  @@schema("medicalrecord")
}

// ══════════════════════════════════════════════════════════════════════════════
//  DISPOSISI / OUTCOME EPISODE (tab Pasien Pulang, IGD) — keputusan akhir kunjungan.
//  Jenis: Pulang / Rawat_Inap / Rujuk / Meninggal / APS. Ditulis HANYA via aksi
//  "Selesaikan Kunjungan" (complete) — atomik bersama transisi InService→Completed
//  + kunci (encounter.Kunjungan.lockedAt/selesaiAt). Append latest-wins per kunjungan
//  (re-complete pasca batal-selesai = baris baru; latest by createdAt = berlaku);
//  pointer jenis di-cache ke Kunjungan.disposisi. TTV keluar TIDAK disimpan di sini
//  (single-source Observation). Gate clinical.keperawatan (Dokter/Perawat). Mirror
//  PasienPulangTab (StatusPulang + sub-panel per jenis).

model Disposisi {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Inti ──
  jenis          String   // Pulang/Rawat_Inap/Rujuk/Meninggal/APS (Zod)
  waktuKeluar    DateTime @map("waktu_keluar") @db.Timestamptz(3)
  dokter         String   // dokter penanggung jawab pulang (nama denormalisasi)
  kondisiUmum    String   @map("kondisi_umum") // Sembuh/Membaik/Tetap/Memburuk (vocab)
  diagnosaKeluar String[] @map("diagnosa_keluar") // snapshot label/kode diagnosa keluar
  instruksi      String   @default("") // instruksi pulang / kontrol

  // ── Blok per-jenis (opsional, diisi sesuai jenis) ──
  rujukTujuan      String? @map("rujuk_tujuan")
  rujukAlasan      String? @map("rujuk_alasan")
  meninggalWaktu   String? @map("meninggal_waktu") // waktu kematian (string FE)
  meninggalSebab   String? @map("meninggal_sebab")
  apsAlasan        String? @map("aps_alasan")
  rawatInapRuangan String? @map("rawat_inap_ruangan")
  rawatInapKelas   String? @map("rawat_inap_kelas")
  catatan          String?

  // ── Pencatat + author (dari actor) ──
  pemeriksa       String  // nama denormalisasi pencatat (dari user login)
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  // ── Audit (append latest-wins + soft-delete medico-legal) ──
