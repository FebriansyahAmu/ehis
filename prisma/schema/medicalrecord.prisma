// ════════════════════════════════════════════════════════════════════════════
//  MODUL: MEDICAL RECORD / Rekam Medis  (Postgres schema "medicalrecord")
//  Acuan: TODO-CLINICAL.md · docs/BACKEND-FLOWS.md · form referensi:
//  TriaseTab / TriasePrimaryForm (TriaseEntryForm).
//
//  Domain klinis menggantung pada spine encounter.Kunjungan via kunjunganId
//  (FK riil lintas-schema, 1 DB). SATU set tabel rekam medis dipakai lintas unit
//  (IGD/RI/RJ) — bukan tabel per-modul.
//
//  PRINSIP: append-only (medico-legal/SNARS) — tiap simpan = baris immutable;
//  koreksi = baris/addendum baru. Denormalisasi ringkas (mis. kunjungan.triaseLevel)
//  = pointer/cache ke baris terbaru, di-sync dalam transaksi milik Service.
//
//  Konvensi (FLOWS §9): uuid v7 · timestamptz · enum hanya untuk field keputusan-
//  kritis · multi-select = text[] · narasi bebas = text.
// ════════════════════════════════════════════════════════════════════════════

// ── Enums ─────────────────────────────────────────────────────────────────---

/// Keputusan triase (selaras TriageLevel frontend: P1=Merah … P4=Hitam).
/// Sinkron ke encounter.Kunjungan.triaseLevel (Int 1..4) oleh Service.
enum TriaseLevel {
  P1
  P2
  P3
  P4

  @@schema("medicalrecord")
}

// ── Triase (pengkajian gawat darurat IGD) ─────────────────────────────────────
//  1 baris = 1 pengkajian triase. Re-triase = baris baru; latest by createdAt =
//  current. Field mirror TriaseEntryForm (TriasePrimaryForm.tsx).

model Triase {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Informasi kedatangan ──
  caraMasuk   String @map("cara_masuk")   // Jalan Kaki/Kursi Roda/Brankar/Ambulans…
  kondisiTiba String @map("kondisi_tiba") // Sadar/Penurunan Kesadaran/Tidak Sadar…

  // ── Anamnesis keluhan utama ──
  keluhanUtama    String  @map("keluhan_utama")
  onset           String
  lokasiKeluhan   String? @map("lokasi_keluhan")
  kualitasKeluhan String? @map("kualitas_keluhan")
  skalaBerat      String? @map("skala_berat")
  faktorPemberat  String? @map("faktor_pemberat")
  faktorPeringan  String? @map("faktor_peringan")
  gejalaPenyerta  String[] @map("gejala_penyerta")
  riwayatSerupa   String? @map("riwayat_serupa")

  // ── Primary survey ABCDE ──
  airwayStatus       String   @map("airway_status")
  suaraNapasAbnormal String[] @map("suara_napas_abnormal")
  breathingQuality   String   @map("breathing_quality")
  pergerakanDada     String?  @map("pergerakan_dada")
  ototBantu          String?  @map("otot_bantu")
  sianosis           String?
  nadiTeraba         String   @map("nadi_teraba")
  kualitasNadi       String?  @map("kualitas_nadi")
  crt                String?
  kondisiKulit       String?  @map("kondisi_kulit")
  perdarahan         String?
  avpu               String
  pupil              String?
  refleksCahaya      String?  @map("refleks_cahaya")
  traumaLuka         String?  @map("trauma_luka")
  lokasiLuka         String?  @map("lokasi_luka")
  suhuKulit          String?  @map("suhu_kulit")

  // ── Diagnosa sementara & tindakan awal ──
  diagnosisSementara String?  @map("diagnosis_sementara")
  tindakanTriase     String[] @map("tindakan_triase")

  // ── Keputusan ──
  triageLevel TriaseLevel @map("triage_level")

  // ── Protokol panduan (master.TriaseProtocol yang dipakai saat observasi) ──
  //  Snapshot kode/nama (medico-legal: stabil walau master berubah). protocolId =
  //  pointer lunak lintas-schema (TANPA FK riil — master criteria di-replace tiap edit).
  protocolId   String? @map("protocol_id") @db.Uuid
  protocolKode String? @map("protocol_kode")
  protocolNama String? @map("protocol_nama")

  // ── Penanggung jawab + author (dari actor) ──
  perawatTriase  String    @map("perawat_triase") // nama denormalisasi (tampilan)
  waktuTriase    DateTime  @map("waktu_triase") @db.Timestamptz(3)
  authorUserId   String?   @map("author_user_id") @db.Uuid
  authorPegawaiId String?  @map("author_pegawai_id") @db.Uuid

  // ── Audit (append-only: tanpa updatedAt/soft-delete; version utk konsistensi) ──
  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  // ── Kriteria observasi yang dicentang perawat/dokter (decision-support → record) ──
  selectedCriteria TriaseCriteria[]

  @@index([kunjunganId, createdAt]) // ambil baris terbaru per kunjungan
  @@map("triase")
  @@schema("medicalrecord")
}

// ── Kriteria triase terpilih (centang panduan) ────────────────────────────────
//  1 baris = 1 item kriteria yang dicentang dari "Tabel Kriteria Triase" saat
//  observasi. SNAPSHOT teks (parameter/level/nilai) → tetap utuh walau master
//  protokol diubah/dihapus (append-only medico-legal; sumber di master di-replace
//  tiap edit, jadi TANPA FK riil ke master.TriaseProtocolCriteria — `sourceCriteriaId`
//  hanya jejak lunak). Urut tampil mengikuti parameter×level lalu `urutan`.

model TriaseCriteria {
  id String @id @default(uuid(7)) @db.Uuid

  triaseId String @map("triase_id") @db.Uuid
  triase   Triase @relation(fields: [triaseId], references: [id], onDelete: Cascade)

  // ── Snapshot sel matrix (parameter × level) ──
  parameterKode  String @map("parameter_kode")
  parameterLabel String @map("parameter_label")
  levelKode      String @map("level_kode")
  levelLabel     String @map("level_label")
  /// Teks item kriteria yang dicentang (mis. "RR > 30, distress berat").
  nilai          String

  /// Jejak lunak ke master.TriaseProtocolCriteria saat dicentang (boleh basi → null OK).
  sourceCriteriaId String? @map("source_criteria_id") @db.Uuid
  /// Urutan tampil dalam satu pengkajian (mengikuti urutan baris matrix).
  urutan    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([triaseId])
  @@map("triase_criteria")
  @@schema("medicalrecord")
}

// ── Observation (TTV / tanda-tanda vital) ─────────────────────────────────────
//  Time-series append-only: 1 baris = 1 pengukuran TTV pada satu titik waktu.
//  BANYAK baris per kunjungan (monitoring berkala) — beda dari Triase (≈1 baris).
//  latest by waktuObservasi = TTV terkini. Field mirror RITTVRecord + IGDVitalSigns
//  (TTVTab.tsx). NEWS2 TIDAK disimpan → derived di FE dari nilai TTV (hindari drift,
//  prinsip sama dgn "jangan simpan angka turunan").
//
//  Shared lintas unit (IGD/RI/RJ) — satu tabel, di-key kunjunganId. statusKesadaran &
//  shift = vocab terkontrol disimpan sbg String (precedent Triase.avpu) — enum Postgres
//  hanya utk field keputusan-kritis (FLOWS §9), kesadaran/shift bukan termasuk.

model Observation {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Tanda-tanda vital (mirror IGDVitalSigns) ──
  tdSistolik  Int    @map("td_sistolik")
  tdDiastolik Int    @map("td_diastolik")
  nadi        Int
  respirasi   Int
  suhu        Float
  spo2        Int
  gcsEye      Int    @map("gcs_eye")
  gcsVerbal   Int    @map("gcs_verbal")
  gcsMotor    Int    @map("gcs_motor")
  skalaNyeri  Int    @map("skala_nyeri") // NRS 0..10
  beratBadan  Float? @map("berat_badan")
  tinggiBadan Float? @map("tinggi_badan")

  // ── Penilaian kesadaran (Compos_Mentis/Apatis/Somnolen/Sopor/Koma) ──
  statusKesadaran String @map("status_kesadaran")

  // ── Konteks pencatatan ──
  shift   String? // Pagi/Siang/Malam (label periode kerja; opsional, bisa diturunkan dari waktu)
  perawat String // nama denormalisasi (tampilan)

  // ── Waktu klinis + author (dari actor) ──
  waktuObservasi  DateTime @map("waktu_observasi") @db.Timestamptz(3)
  authorUserId    String?  @map("author_user_id") @db.Uuid
  authorPegawaiId String?  @map("author_pegawai_id") @db.Uuid

  // ── Audit (append-only: tanpa updatedAt/soft-delete; version utk konsistensi) ──
  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([kunjunganId, waktuObservasi]) // time-series per kunjungan (terbaru dulu)
  @@map("observation")
  @@schema("medicalrecord")
}

// ── Anamnesis (Asesmen Medis · sub: Anamnesis) ────────────────────────────────
//  Asesmen medis awal (AP 1.1) — keluhan + RPS + status generalis + obat saat ini.
//  Append-only "latest wins" (mirip Triase, ≈1 baris/kunjungan): dilakukan saat intake,
//  koreksi = baris baru; latest by createdAt = berlaku. Field mirror AnamnesisIGDForm
//  (AsesmenMedisTab.tsx > AnamnesisPane). Shared lintas unit — vocab terkontrol (sumber
//  anamnesis) disimpan String (precedent). Pemeriksa = nama user login (dari actor).

model Anamnesis {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Spine (FK riil, same DB / cross-schema ke encounter) ──
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  // ── Sumber & keluhan ──
  sumberAnamnesis String @map("sumber_anamnesis") // Pasien/Keluarga/Pengantar/Rekam Medis
  keluhanUtama    String @map("keluhan_utama")
  rps             String @map("riwayat_penyakit_sekarang")

  // ── Karakter keluhan (opsional) ──
  onsetDurasi     String? @map("onset_durasi")
  mekanismeCedera String? @map("mekanisme_cedera") // relevan bila trauma
  faktorPemberat  String? @map("faktor_pemberat")
  faktorPeringan  String? @map("faktor_peringan") // FE form key `faktorPemerut` (typo) → di-map saat wiring

  // ── Status generalis & obat ──
  statusGeneralis String  @map("status_generalis") // keadaan umum (pemeriksaan fisik lengkap = domain Assessment lain)
  obatSaatIni     String? @map("obat_saat_ini") // snapshot bebas (riwayat obat lengkap = domain Riwayat)

  // ── Pemeriksa + author (dari actor) ──
  pemeriksa       String  // nama denormalisasi pencatat (dari user login)
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  // ── Audit (append-only: tanpa updatedAt/soft-delete; version utk konsistensi) ──
  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt]) // ambil baris terbaru per kunjungan
  @@map("anamnesis")
  @@schema("medicalrecord")
}

// ══════════════════════════════════════════════════════════════════════════════
//  ASESMEN MEDIS · sub-menu RIWAYAT MEDIS — tiap pane = domain/tabel sendiri
//  (prefix `asesmen_`). Append-only "latest wins" (≈1 baris/kunjungan, koreksi =
//  baris baru) untuk pane single-record; pane berdaftar pakai parent + child snapshot
//  (pola Triase+TriaseCriteria). Mirror RiwayatPane sub-panes (AsesmenMedisTab.tsx).
// ══════════════════════════════════════════════════════════════════════════════

// ── Riwayat Penyakit Dahulu (RPD) ─────────────────────────────────────────────
//  Daftar penyakit yg pernah diderita (multi-select → text[]) + catatan bebas.
model AsesmenPenyakitDahulu {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  penyakit String[] // penyakit tercentang (Hipertensi/DM/PJK/…)
  catatan  String? // keterangan tambahan (tahun diagnosis, komplikasi, dll)

  // ── Pemeriksa + author (dari actor) ──
  pemeriksa       String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt])
  @@map("asesmen_penyakit_dahulu")
  @@schema("medicalrecord")
}

// ── Gaya Hidup (sub "Lainnya": merokok · paparan asap · kebiasaan) ────────────
model AsesmenGayaHidup {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  merokokStatus String?  @map("merokok_status") // ya/tidak/mantan
  rokokPerHari  String?  @map("rokok_per_hari")
  merokokSejak  String?  @map("merokok_sejak")
  berhentiSejak String?  @map("berhenti_sejak")
  paparanAsap   Boolean? @map("paparan_asap")
  paparanDetail String?  @map("paparan_detail")
  catatan       String?

  pemeriksa       String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt])
  @@map("asesmen_gaya_hidup")
  @@schema("medicalrecord")
}

// ── Faktor Resiko (penyakit beresiko + perilaku beresiko) ─────────────────────
model AsesmenFaktorResiko {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  penyakit     String[] // penyakit beresiko tercentang
  penyakitLain String?  @map("penyakit_lain")
  perilaku     String[] // perilaku beresiko tercentang
  perilakuLain String?  @map("perilaku_lain")

  pemeriksa       String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt])
  @@map("asesmen_faktor_resiko")
  @@schema("medicalrecord")
}

// ── Tuberkulosis (riwayat TBC · OAT · TCM · sputum BTA) ───────────────────────
model AsesmenTuberkulosis {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  riwayatTbc      Boolean? @map("riwayat_tbc")
  tahunPengobatan String?  @map("tahun_pengobatan")
  statusOat       String?  @map("status_oat") // selesai/tidak-selesai/sedang-berjalan
  kontakTbc       Boolean? @map("kontak_tbc")
  penunjang       String?
  tcmDilakukan    Boolean? @map("tcm_dilakukan")
  tcmHasil        String?  @map("tcm_hasil") // pos-sensitif/pos-resisten/negatif/invalid
  sputumDilakukan Boolean? @map("sputum_dilakukan")
  sputumHasil     String?  @map("sputum_hasil") // positif/negatif
  sputumGrade     String?  @map("sputum_grade")
  catatan         String?

  pemeriksa       String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt])
  @@map("asesmen_tuberkulosis")
  @@schema("medicalrecord")
}

// ── Ginekologi (menstruasi · skrining Pap Smear/IVA) ──────────────────────────
model AsesmenGinekologi {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  statusMenstruasi String?  @map("status_menstruasi")
  hpht             String? // FE input date → simpan string (mirror form)
  siklus           String?
  lamaMenstruasi   String?  @map("lama_menstruasi")
  dismenorea       Boolean?
  menoragia        Boolean?
  keputihan        Boolean?
  papSmear         Boolean? @map("pap_smear")
  papTahun         String?  @map("pap_tahun")
  papHasil         String?  @map("pap_hasil")
  iva              Boolean?
  ivaTahun         String?  @map("iva_tahun")
  ivaHasil         String?  @map("iva_hasil")
  catatan          String?

  pemeriksa       String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([kunjunganId, createdAt])
  @@map("asesmen_ginekologi")
  @@schema("medicalrecord")
}

// ══════════════════════════════════════════════════════════════════════════════
//  RIWAYAT MEDIS — pane berdaftar (parent + child snapshot, pola Triase+TriaseCriteria).
//  Append-only "latest wins": tiap simpan = parent baru + children-nya; latest by
//  createdAt = berlaku. Children = snapshot baris saat simpan (urut `urutan`).
// ══════════════════════════════════════════════════════════════════════════════

// ── Pemberian Obat ────────────────────────────────────────────────────────────
model AsesmenObat {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  pemeriksa       String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  items AsesmenObatItem[]

  @@index([kunjunganId, createdAt])
  @@map("asesmen_obat")
  @@schema("medicalrecord")
}

model AsesmenObatItem {
  id            String      @id @default(uuid(7)) @db.Uuid
  asesmenObatId String      @map("asesmen_obat_id") @db.Uuid
  asesmenObat   AsesmenObat @relation(fields: [asesmenObatId], references: [id], onDelete: Cascade)

  nama      String
  dosis     String?
  frekuensi String?
  rute      String?
  sejak     String?
  indikasi  String?
  urutan    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([asesmenObatId])
  @@map("asesmen_obat_item")
  @@schema("medicalrecord")
}

// ── Penyakit Keluarga (per anggota keluarga) ──────────────────────────────────
model AsesmenPenyakitKeluarga {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  riwayatLain String? @map("riwayat_lain") // catatan herediter/genetik bebas

  pemeriksa       String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  items AsesmenPenyakitKeluargaItem[]

  @@index([kunjunganId, createdAt])
  @@map("asesmen_penyakit_keluarga")
  @@schema("medicalrecord")
}

model AsesmenPenyakitKeluargaItem {
  id                        String                  @id @default(uuid(7)) @db.Uuid
  asesmenPenyakitKeluargaId String                  @map("asesmen_penyakit_keluarga_id") @db.Uuid
  asesmenPenyakitKeluarga   AsesmenPenyakitKeluarga @relation(fields: [asesmenPenyakitKeluargaId], references: [id], onDelete: Cascade)

  anggota    String // Ayah/Ibu/Kakak/…
  penyakit   String[] // penyakit tercentang utk anggota itu
  keterangan String?
  urutan     Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([asesmenPenyakitKeluargaId])
  @@map("asesmen_penyakit_keluarga_item")
  @@schema("medicalrecord")
}

// ── Perawatan & Tindakan (2 daftar: rawat inap + pembedahan) ──────────────────
model AsesmenPerawatan {
  id String @id @default(uuid(7)) @db.Uuid

  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  pemeriksa       String
  authorUserId    String? @map("author_user_id") @db.Uuid
  authorPegawaiId String? @map("author_pegawai_id") @db.Uuid

  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  rawatItems      AsesmenRawatInapItem[]
  pembedahanItems AsesmenPembedahanItem[]

  @@index([kunjunganId, createdAt])
  @@map("asesmen_perawatan")
  @@schema("medicalrecord")
}

model AsesmenRawatInapItem {
  id                String           @id @default(uuid(7)) @db.Uuid
  asesmenPerawatanId String          @map("asesmen_perawatan_id") @db.Uuid
  asesmenPerawatan  AsesmenPerawatan @relation(fields: [asesmenPerawatanId], references: [id], onDelete: Cascade)

  rs         String?
  unit       String?
  tanggal    String? // FE date input → simpan string
  diagnosa   String?
  keterangan String?
  urutan     Int      @default(0)
