  tindakan   String?
  rs         String?
  dokter     String?
  keterangan String?
  urutan     Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([asesmenPerawatanId])
  @@map("asesmen_pembedahan_item")
  @@schema("medicalrecord")
}

// ── Obstetri (KB + GPA + ANC scalar; persalinan = daftar) ─────────────────────
