// ════════════════════════════════════════════════════════════════════════════
//  MODUL: ENCOUNTER / Kunjungan  (Postgres schema "encounter", tabel "kunjungan")
//  Acuan: docs/BACKEND-ENCOUNTER.md · form referensi: modal "Pendaftaran Kunjungan
//  Baru" (DaftarKunjunganModal — wizard Kunjungan/Penjamin/Rujukan/SEP).
//
//  Kunjungan = SUMBU TUNGGAL (spine state machine). 1 baris = 1 episode kunjungan
//  (IGD/RawatJalan/RawatInap). Menyembuhkan 2 break spine: worklist = query
//  (unit,status); invoice dibuat saat Registered→Queued. Data klinis/transaksional
//  TIDAK di sini → menggantung via kunjunganId.
//
//  Relasi flow:
//    pendaftaran.Pasien 1───* Kunjungan                 (siapa yang berkunjung)
//    pendaftaran.PasienPenjamin 1───* Kunjungan         (penjamin dipakai; no. BPJS di penjamin)
//    Kunjungan 1───0..1 bpjs.Rujukan                    (rujukan masuk / kontrol pasca ranap)
//    Kunjungan 1───0..1 bpjs.SEP                         (SEP terbit utk kunjungan ini)
//    bpjs.SEP *───0..1 bpjs.Rujukan                      (SEP dibuat dari rujukan)
//
//  FK riil: patientId/penjaminId → pendaftaran (lintas-schema, 1 DB). Tautan domain
//  belum-ada (dpjp/antrean/invoice/bed) = UUID placeholder, jadikan FK saat modul siap.
//
//  Konvensi (FLOWS §9): uuid v7 · timestamptz · soft-delete · optimistic concurrency.
// ════════════════════════════════════════════════════════════════════════════

// ── Enums ─────────────────────────────────────────────────────────────────---

enum KunjunganUnit {
  IGD
  RawatJalan
  RawatInap

  @@schema("encounter")
}

/// Lifecycle terpadu worklist lintas unit (BACKEND-ENCOUNTER §3).
enum KunjunganStatus {
  Registered
  Queued
  InService
  Completed
  Closed
  Billed
  Claimed
  Cancelled

  @@schema("encounter")
}

/// Sub-state panggilan (RJ/farmasi) — TIDAK mengubah status puncak.
enum CallState {
  Idle
  Dipanggil

  @@schema("encounter")
}

/// Kelas rawat (RI) — selaras RIKelas frontend (data.ts).
enum KelasRawat {
  VIP
  Kelas_1
  Kelas_2
  Kelas_3
  ICU
  HCU
  Isolasi

  @@schema("encounter")
}

/// Lifecycle alokasi bed. Reserved (di-hold, RI saat daftar) & Occupied (terisi, mis. IGD saat
/// terima) sama-sama "memakai" bed (masuk partial unique index). Released = bebas kembali.
enum AllocStatus {
  Reserved
  Occupied
  Released

  @@schema("encounter")
}

// ── Kunjungan (tabel inti / spine) ────────────────────────────────────────────

model Kunjungan {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Pasien (FK riil lintas-schema) ──
  patientId String @map("patient_id") @db.Uuid
  pasien    Pasien @relation(fields: [patientId], references: [id], onDelete: Restrict)

  // ── Header ──
  unit           KunjunganUnit
  status         KunjunganStatus @default(Registered)
  /// "RJ/2026/xxxx" — Service generate (sequence per unit).
  noKunjungan    String          @unique @map("no_kunjungan")
  noPendaftaran  String?         @map("no_pendaftaran") // "REG-..."
  /// Waktu kunjungan (tanggal + jam dari modal, digabung di Service).
  waktuKunjungan DateTime        @default(now()) @map("waktu_kunjungan") @db.Timestamptz(3)

  /// Link spine TaskID antrol (RJ/onsite/MJKN). FK→Antrean saat modul siap.
  antreanKodebooking String? @unique @map("antrean_kodebooking")
  /// DPJP/dokter. FK→master Dokter (via master.Pegawai.practitionerId) saat siap.
  dpjpId             String? @map("dpjp_id") @db.Uuid
  /// Ruangan layanan (IGD: bay/zona triase; RJ: poli-room). FK→master Location saat siap.
  /// Placeholder UUID (selaras bedId/dpjpId) — dipilih dari master Ruangan saat pendaftaran.
  ruanganId          String? @map("ruangan_id") @db.Uuid

  // ── Field per-unit (validasi unit-spesifik di Zod/Service) ──
  poli        String? // RJ — poli tujuan
  kelas       KelasRawat? // RI
  /// Bed RI — FK→master Bed/Ruangan saat siap. Alokasi/status bed bukan domain ini.
  bedId       String?     @map("bed_id") @db.Uuid
  triaseLevel Int?        @map("triase_level") // IGD 1..5 (CHECK di SQL)
  caraDatang  String?     @map("cara_datang") // IGD: Jalan Kaki/Ambulans/Kendaraan Pribadi
  asalMasuk   String?     @map("asal_masuk") // RI: Dari IGD/Dari Poli/Langsung

  // ── Sub-state panggilan (kolom sekunder, bukan status puncak) ──
  callState   CallState? @map("call_state")
  recallCount Int        @default(0) @map("recall_count")

  // ── Klinis masuk ──
  caraMasuk     String? @map("cara_masuk")
  keluhan       String? // keluhan masuk (text, opsional)
  /// Diagnosa masuk (denormalisasi dari rujukan utk tampilan cepat; otoritatif di bpjs.Rujukan).
  diagnosaMasuk String? @map("diagnosa_masuk")
  kodeIcdMasuk  String? @map("kode_icd_masuk") // ICD-10

  // ── Penjamin kunjungan (snapshot tipe utk worklist + FK ke penjamin pasien) ──
  penjaminTipe TipePenjamin    @default(Umum) @map("penjamin_tipe")
  /// Penjamin yang dipakai utk kunjungan ini. No. kartu/BPJS disimpan di PasienPenjamin (enc).
  penjaminId   String?         @map("penjamin_id") @db.Uuid
  penjamin     PasienPenjamin? @relation(fields: [penjaminId], references: [id], onDelete: SetNull)

  // ── BPJS (1:1, schema bpjs) ──
  rujukan Rujukan?
  sep     SEP?

  // ── Alokasi bed (operasional; okupansi/reservasi) ──
  bedAllocations BedAllocation[]

  // ── Klinis (schema medicalrecord; menggantung via kunjunganId) ──
  triase                Triase[]
  observation           Observation[]
  anamnesis             Anamnesis[]
  asesmenPenyakitDahulu AsesmenPenyakitDahulu[]
  asesmenGayaHidup      AsesmenGayaHidup[]
  asesmenFaktorResiko   AsesmenFaktorResiko[]
  asesmenTuberkulosis   AsesmenTuberkulosis[]
  asesmenGinekologi     AsesmenGinekologi[]

  // ── Tautan invoice (1:1, dibuat saat Registered→Queued) ──
  invoiceId String? @unique @map("invoice_id") @db.Uuid // FK→billing.Invoice saat siap

  // ── Finalize / lock ──
  lockedAt  DateTime? @map("locked_at") @db.Timestamptz(3)
  /// Immutable — di-set sekali saat Completed, dipertahankan saat re-open.
  selesaiAt DateTime? @map("selesai_at") @db.Timestamptz(3)

  // ── Konkurensi & audit ──
  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([unit, status, createdAt]) // worklist (query terpanas)
  @@index([patientId]) // timeline pasien
  @@index([penjaminId])
  @@index([dpjpId])
  @@index([ruanganId])
  @@index([createdAt, id]) // cursor pagination
  @@map("kunjungan")
  @@schema("encounter")
}

// ── BedAllocation (okupansi/reservasi bed) ─────────────────────────────────────
//  Sumber kebenaran okupansi: 1 baris = 1 bed dipakai 1 kunjungan. "Tersedia" = DIHITUNG
//  (bed master aktif − alokasi aktif), BUKAN counter (anti drift/race). Double-booking dicegah
//  partial unique index (status ∈ {Reserved,Occupied}) yang ditambah via SQL di migration.
//  bedId = FK riil ke master.Bed tapi cross-schema → tanpa relasi Prisma (validasi di Service,
//  selaras konvensi placeholder patientId/ruanganId).

model BedAllocation {
  id String @id @default(uuid(7)) @db.Uuid

  bedId       String    @map("bed_id") @db.Uuid // → master.Bed (cross-schema; divalidasi Service)
  kunjunganId String    @map("kunjungan_id") @db.Uuid
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  status     AllocStatus @default(Reserved)
  reservedAt DateTime    @default(now()) @map("reserved_at") @db.Timestamptz(3)
  occupiedAt DateTime?   @map("occupied_at") @db.Timestamptz(3)
  releasedAt DateTime?   @map("released_at") @db.Timestamptz(3)

  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([bedId])
  @@index([kunjunganId])
  @@map("bed_allocation")
  @@schema("encounter")
}
