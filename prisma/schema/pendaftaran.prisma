// ════════════════════════════════════════════════════════════════════════════
//  MODUL: PENDAFTARAN / Pasien  (Postgres schema "pendaftaran")
//  Acuan: docs/BACKEND-PATIENT.md · form referensi: PasienBaruModal (3 step).
//
//  Pasien = identitas TUNGGAL (1 baris = 1 manusia) + demografi stabil. Akar
//  bersama Encounter (FK Encounter.pasienId → modul encounter, dibuat nanti).
//  Data yang berubah per-kunjungan TIDAK di sini (→ Encounter / domain klinis).
//
//  Identitas: NIK = anchor dedup + kunci Practitioner/Patient FHIR (enc+hash, PII).
//             noRM = sequence "RM-{th}-{seq}" (atomik; ganti max+1 race-prone mock).
//             Mr.X (isAnonim) → NIK null; @unique nullable membiarkan banyak NULL.
//
//  Konvensi (FLOWS §9): uuid v7 · timestamptz · citext · soft-delete · optimistic
//  concurrency (version) · @@schema("pendaftaran"). PII di-encrypt app-level di Service.
// ════════════════════════════════════════════════════════════════════════════

// ── Enums (codeset legal-stabil; agama/pendidikan = text + TODO master) ───────

enum Gender {
  L
  P

  @@schema("pendaftaran")
}

enum GolonganDarah {
  A
  B
  AB
  O
  TidakDiketahui

  @@schema("pendaftaran")
}

enum Rhesus {
  Positif
  Negatif
  TidakDiketahui

  @@schema("pendaftaran")
}

/// Standar Dukcapil (frontend lama Janda/Duda + Cerai → map di adapter saat swap).
enum StatusPerkawinan {
  BelumKawin
  Kawin
  CeraiHidup
  CeraiMati

  @@schema("pendaftaran")
}

/// Selaras TipePenjamin frontend (data.ts). COB (BPJS+swasta) = fase later di Encounter/Claim.
enum TipePenjamin {
  Umum
  BPJS_Non_PBI
  BPJS_PBI
  Asuransi
  Jamkesda

  @@schema("pendaftaran")
}

/// KTP (sesuai kartu) vs Domisili (tempat tinggal nyata). Form: flag `samaAlamat`.
enum JenisAlamat {
  KTP
  Domisili

  @@schema("pendaftaran")
}

/// Asal record pasien pertama kali dibuat (audit). Bukan asal kunjungan.
enum SumberPendaftaran {
  WalkIn
  MJKN
  Kiosk

  @@schema("pendaftaran")
}

// ── Pasien (identitas inti) ───────────────────────────────────────────────────

model Pasien {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Identitas ──
  /// Format "RM-{th}-{seq}" dari sequence pendaftaran.no_rm_seq (Service, atomik).
  noRm String @unique @map("no_rm")
  /// NIK terenkripsi (PII). Nullable HANYA utk Mr.X (isAnonim) — dilengkapi saat identitas diketahui.
  nikEnc  String? @map("nik_enc")
  /// HMAC-SHA256 NIK utk dedup/lookup (ciphertext tak bisa di-WHERE). @unique nullable:
  /// Postgres anggap NULL berbeda → banyak Mr.X (NULL) boleh, NIK asli wajib unik (anti double-MRN).
  nikHash String? @unique @map("nik_hash")
  /// No. Kartu Keluarga (dari BPJS/Dukcapil) — PII enc. Hash opsional utk lookup keluarga.
  noKkEnc  String? @map("no_kk_enc")
  noKkHash String? @map("no_kk_hash")

  /// WNA — tak punya NIK 16-digit, identitas via paspor. Identitas inti dijaga CHECK:
  /// non-anonim WAJIB punya NIK ATAU paspor (pasien_identitas_chk).
  isWna        Boolean @default(false) @map("is_wna")
  /// No. paspor terenkripsi (PII, WNA). Hash @unique nullable utk dedup (NULL = WNI/tak relevan).
  noPasporEnc  String? @map("no_paspor_enc")
  noPasporHash String? @unique @map("no_paspor_hash")

  nama         String
  gender       Gender
  tempatLahir  String?   @map("tempat_lahir")
  tanggalLahir DateTime? @map("tanggal_lahir") @db.Date
  // Umur DIHITUNG dari tanggalLahir (now() injectable di Service) — tidak disimpan.

  golonganDarah    GolonganDarah?    @map("golongan_darah")
  rhesus           Rhesus?
  statusPerkawinan StatusPerkawinan? @map("status_perkawinan")
  // TODO(master): agama/pendidikan/pekerjaan/suku → master-reference (kode SatuSehat) saat siap.
  agama            String?
  pendidikan       String?
  pekerjaan        String?
  suku             String?
  kewarganegaraan  String            @default("WNI")

  // ── Kontak ──
  noHp  String? @map("no_hp")
  email String? @db.Citext

  // ── FHIR / SatuSehat ──
  /// Patient resource id SatuSehat (hasil sync via NIK). Plain string sampai modul fhir.
  idSatusehat String? @map("id_satusehat")

  // ── State / lifecycle (FLOWS §10) ──
  /// false = draft minimal (kiosk/MJKN), true = lengkap (diisi saat admisi).
  dataLengkap Boolean            @default(false) @map("data_lengkap")
  /// Mr.X — pasien tak dikenal IGD (NIK kosong, lewati dedup sampai identitas diketahui).
  isAnonim    Boolean            @default(false) @map("is_anonim")
  sumberDaftar SumberPendaftaran? @map("sumber_daftar")

  /// Bila record ini hasil merge → menunjuk survivor. Lookup di-redirect ke survivor.
  mergedIntoId String?  @map("merged_into_id") @db.Uuid
  mergedInto   Pasien?  @relation("PasienMerge", fields: [mergedIntoId], references: [id])
  mergedFrom   Pasien[] @relation("PasienMerge")

  /// Optimistic concurrency (FLOWS): Service bump + guard expectedVersion saat update.
  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  // ── Relasi (sub-koleksi) ──
  alamat        PasienAlamat[]
  penjamin      PasienPenjamin[]
  alergiAwal    PasienAlergiAwal[]
  kontakDarurat PasienKontakDarurat[]
  /// Kunjungan pasien (back-relation; FK di encounter.Encounter.patientId, lintas-schema).
  encounters    Encounter[]

  // GIN trigram (pg_trgm) → search nama typo-tolerant. Butuh extension pg_trgm.
  @@index([nama(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([tanggalLahir])
  @@index([mergedIntoId])
  @@map("pasien")
  @@schema("pendaftaran")
}

// ── Alamat (1:N — KTP + Domisili; form `samaAlamat` → 1 baris KTP saja) ───────

model PasienAlamat {
  id       String      @id @default(uuid(7)) @db.Uuid
  pasienId String      @map("pasien_id") @db.Uuid
  jenis    JenisAlamat

  alamat  String?
  rtRw    String? @map("rt_rw")
  kodePos String? @map("kode_pos")

  // Kode wilayah KEMENDAGRI (numerik) — utk FHIR administrativeCode.
  provinsiKode  String? @map("provinsi_kode")
  provinsiNama  String? @map("provinsi_nama")
  kotaKode      String? @map("kota_kode")
  kotaNama      String? @map("kota_nama")
  kecamatanKode String? @map("kecamatan_kode")
  kecamatanNama String? @map("kecamatan_nama")
  kelurahanKode String? @map("kelurahan_kode")
  kelurahanNama String? @map("kelurahan_nama")

  // Kode BPJS APA ADANYA (≠ Kemendagri) — resolve ke Kemendagri via master mapping saat sync.
  bpjsKodeProp  String? @map("bpjs_kode_prop")
  bpjsKodeDati2 String? @map("bpjs_kode_dati2")
  bpjsKodeKec   String? @map("bpjs_kode_kec")
  bpjsKodeKel   String? @map("bpjs_kode_kel")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  pasien Pasien @relation(fields: [pasienId], references: [id], onDelete: Cascade)

  @@unique([pasienId, jenis]) // max 1 KTP + 1 Domisili per pasien
  @@map("pasien_alamat")
  @@schema("pendaftaran")
}

// ── Penjamin (1:N — 1 primer; COB multi-penjamin forward-compat) ──────────────

model PasienPenjamin {
  id       String       @id @default(uuid(7)) @db.Uuid
  pasienId String       @map("pasien_id") @db.Uuid
  tipe     TipePenjamin
  nama     String

  /// No. kartu/peserta — PII enc. Hash utk lookup (cek peserta BPJS).
  nomorEnc  String? @map("nomor_enc")
  nomorHash String? @map("nomor_hash")
  kelas     String? // "1" | "2" | "3" (BPJS) — validasi enum di Zod, bukan DB

  berlakuSampai DateTime? @map("berlaku_sampai") @db.Date
  noPolis       String?   @map("no_polis")
  isPrimer      Boolean   @default(true) @map("is_primer")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  pasien Pasien @relation(fields: [pasienId], references: [id], onDelete: Cascade)

  @@index([pasienId])
  @@map("pasien_penjamin")
  @@schema("pendaftaran")
}

// ── Alergi awal (registrasi) — alergi klinis lengkap = domain klinis ──────────

model PasienAlergiAwal {
  id       String  @id @default(uuid(7)) @db.Uuid
  pasienId String  @map("pasien_id") @db.Uuid
  nama     String
  reaksi   String?
  tingkat  String? // ringan/sedang/berat — enum di Zod

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  pasien Pasien @relation(fields: [pasienId], references: [id], onDelete: Cascade)

  @@index([pasienId])
  @@map("pasien_alergi_awal")
  @@schema("pendaftaran")
}

// ── Kontak darurat (1:N) ──────────────────────────────────────────────────────

model PasienKontakDarurat {
  id       String  @id @default(uuid(7)) @db.Uuid
  pasienId String  @map("pasien_id") @db.Uuid
  nama     String
  hubungan String
  noHp     String  @map("no_hp")
  alamat   String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  pasien Pasien @relation(fields: [pasienId], references: [id], onDelete: Cascade)

  @@index([pasienId])
  @@map("pasien_kontak_darurat")
  @@schema("pendaftaran")
}
