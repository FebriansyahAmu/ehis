// ════════════════════════════════════════════════════════════════════════════
//  MODUL: MASTER / Mapping Hub — Formularium Unit  (Postgres schema "master")
//  FE: /ehis-master/mapping (sub-pane Formularium) · Doc: docs/BACKEND-MAPPING.md §6
//
//  Link N:N Obat ⇄ Ruangan (Location): "obat apa MASUK FORMULARIUM (boleh diresepkan)
//  di ruangan/unit mana". Berlaku universal lintas penjamin (BPJS/Umum sama) — TIDAK
//  per-penjamin & TIDAK per-kelas (kelas tercermin implisit dari kelas Ruangan-nya).
//
//  Bentuk PERSIS LayananUnit (Tindakan⇄Location): join table, HARD delete saat dicabut,
//  unik (obat, ruangan) → grant idempoten. Konvensi (FLOWS §9): uuid v7 · timestamptz.
//
//  BEDA dari (jangan tertukar):
//   • Distribusi Obat → Obat ⇄ Depo Farmasi (stok fisik), bukan formularium klinis.
//   • LayananUnit     → Tindakan ⇄ Ruangan, bukan Obat.
//  Catatan federasi (TODO-CHARGEMASTER): saat chargemaster siap, edge ini bisa bersatu.
// ════════════════════════════════════════════════════════════════════════════

model FormulariumObat {
  id String @id @default(uuid(7)) @db.Uuid

  obatId String @map("obat_id") @db.Uuid
  obat   Obat   @relation(fields: [obatId], references: [id], onDelete: Restrict)

  locationId String   @map("location_id") @db.Uuid
  location   Location @relation("FormulariumLokasi", fields: [locationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([obatId, locationId])
  @@index([locationId])
  @@index([obatId])
  @@map("formularium_obat")
  @@schema("master")
}

// ════════════════════════════════════════════════════════════════════════════
//  Ketersediaan Farmasi — BMHP  (sub-pane "BMHP" di Mapping Hub → Ketersediaan Farmasi)
//
//  Link N:N BMHP ⇄ Ruangan (Location): "BMHP apa jadi DAFTAR STANDAR DEPO (distok &
//  boleh diminta) di lokasi farmasi mana". Tabel TERPISAH dari FormulariumObat (Obat ≠
//  BMHP — beda katalog, sejalan keputusan katalog terpisah). Bentuk PERSIS FormulariumObat:
//  join table, HARD delete saat dicabut, unik (bmhp, lokasi) → grant idempoten. Kolom matriks
//  dibatasi Location jenis Farmasi/Gudang_Farmasi (sama dgn Obat). Konvensi: uuid v7 · timestamptz.
//
//  CATATAN istilah: untuk BMHP ini bukan "formularium" klinis (tak ada Fornas BMHP) melainkan
//  daftar barang standar per depo — nama tabel mengikuti pola (formularium_*) demi konsistensi.
// ════════════════════════════════════════════════════════════════════════════

model FormulariumBmhp {
  id String @id @default(uuid(7)) @db.Uuid

  bmhpId String @map("bmhp_id") @db.Uuid
  bmhp   Bmhp   @relation(fields: [bmhpId], references: [id], onDelete: Restrict)

  locationId String   @map("location_id") @db.Uuid
  location   Location @relation("FormulariumBmhpLokasi", fields: [locationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([bmhpId, locationId])
  @@index([locationId])
  @@index([bmhpId])
  @@map("formularium_bmhp")
  @@schema("master")
}
