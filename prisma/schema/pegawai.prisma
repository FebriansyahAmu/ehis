// ════════════════════════════════════════════════════════════════════════════
//  MODUL: MASTER / Kepegawaian (Pegawai)  (Postgres schema "master")  ·  ref: legacy sdm_*
//  Data pegawai (HR) — TERPISAH dari akun login (auth.users). Setiap akun WAJIB
//  terikat ke 1 pegawai (auth.User.pegawaiId NOT NULL) → zero orphan account.
//
//  Identitas: NIK = anchor (enc+hash, PII) untuk validasi provisioning akun.
//             NIP = nomor pegawai unik (resmi ASN / auto-generate non-ASN di Service).
//  Kredensial klinis (STR/SIP/spesialis) TIDAK di sini → master Dokter via practitionerId.
//
//  Jabatan/Golongan struktural DIHAPUS (2026-06-04) — di luar scope MVP master pegawai;
//  jenjang struktural diwakili `unitKerja` + `statusPegawai`. Hidupkan kembali sebagai
//  master-reference bila modul kepegawaian struktural dibutuhkan.
//
//  Konvensi (FLOWS §9): uuid v7 · timestamptz · soft-delete · @@schema("master").
// ════════════════════════════════════════════════════════════════════════════

// ── Enums ─────────────────────────────────────────────────────────────────---

enum JenisKelamin {
  L
  P

  @@schema("master")
}

/// Kategori hubungan kerja (selaras form Tambah Pengguna). ASN = PNS|PPPK (gabung).
/// Outsourcing = eks-Kontrak/alih-daya. Non-ASN → NIP auto-generate di Service (fase later).
enum StatusPegawai {
  ASN
  Outsourcing
  Honorer
  Magang
  Mitra

  @@schema("master")
}

enum StatusAbsensi {
  Hadir
  Izin
  Sakit
  Cuti
  Alpa
  Libur

  @@schema("master")
}

// ── Pegawai (core HR) ──────────────────────────────────────────────────────--

model Pegawai {
  id String @id @default(uuid(7)) @db.Uuid

  // ── Identitas ──
  /// NIK terenkripsi (PII, app-level encrypt). WAJIB — anchor identitas +
  /// kunci ambil Practitioner dari SatuSehat/FHIR (Service decrypt saat sync).
  nikEnc  String @map("nik_enc")
  /// HMAC-SHA256 NIK utk lookup/dedup + uniqueness (ciphertext tak bisa di-WHERE). WAJIB unik.
  nikHash String @unique @map("nik_hash")
  /// Nomor pegawai — resmi (ASN) / auto-generate (non-ASN, di Service).
  nip     String @unique

  namaLengkap   String       @map("nama_lengkap")
  gelarDepan    String?      @map("gelar_depan")
  gelarBelakang String?      @map("gelar_belakang")
  jenisKelamin  JenisKelamin @map("jenis_kelamin")
  agama         String? // agama besar dunia / "Lainnya" (string s/d master reference siap)
  tempatLahir   String?      @map("tempat_lahir")
  tanggalLahir  DateTime?    @map("tanggal_lahir") @db.Date

  // ── Kepegawaian ──
  statusPegawai StatusPegawai @map("status_pegawai")
  /// Jenis tenaga (Dokter/Perawat/Apoteker/…) — sumber kebenaran "user ini profesi apa".
  /// Dokter? = profesi ∈ {Dokter, Dokter Gigi, Dokter Spesialis} ATAU practitionerId terisi.
  profesi       String?
  unitKerja     String?       @map("unit_kerja")
  tglMasuk      DateTime?     @map("tgl_masuk") @db.Date
  // TODO(master): agamaId / pendidikanId / profesiId → master reference saat schema master siap.

  // ── Kontak primer (embedded; kontak darurat → tabel terpisah) ──
  alamat String?
  noHp   String? @map("no_hp")
  email  String? @unique @db.Citext

  foto String?

  /// Link ke master Dokter/Practitioner (hanya pegawai klinis). Plain uuid sampai
  /// model Dokter di schema master siap → jadikan relasi FK nanti. "User dokter?" = practitionerId != null.
  practitionerId String? @map("practitioner_id") @db.Uuid

  isActive Boolean @default(true) @map("is_active")

  /// Optimistic concurrency (FLOWS §7): Service bump + guard expectedVersion saat update.
  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  // ── Relasi ──
  absensi       Absensi[]
  kontakDarurat PegawaiKontakDarurat[]
  /// 1 pegawai : 0..1 akun login (back-relation; FK di auth.User.pegawaiId, lintas-schema).
  user          User?
  /// 1 pegawai : 0..1 profil Dokter (ekstensi klinis; FK di master.Dokter.pegawaiId).
  /// "Pegawai ini dokter?" = relasi ini ada (atau practitionerId terisi sbg pointer denormalized).
  dokter        Dokter? @relation("PegawaiDokter")
  /// Penugasan ke ruangan (Mapping Hub → SDM Assignment); N:M via master.PenugasanRuangan.
  penugasanRuangan PenugasanRuangan[] @relation("PegawaiPenugasan")

  @@index([namaLengkap])
  @@index([statusPegawai])
  @@map("pegawai")
  @@schema("master")
}

// ── Jadwal shift (referensi jam kerja) ────────────────────────────────────────

model JadwalShift {
  id         String   @id @default(uuid(7)) @db.Uuid
  nama       String
  jamMulai   DateTime @map("jam_mulai") @db.Time(0)
  jamSelesai DateTime @map("jam_selesai") @db.Time(0)
  isActive   Boolean  @default(true) @map("is_active")

  @@map("jadwal_shift")
  @@schema("master")
}

// ── Absensi (per pegawai per tanggal) ─────────────────────────────────────────

model Absensi {
  id         String        @id @default(uuid(7)) @db.Uuid
  pegawaiId  String        @map("pegawai_id") @db.Uuid
  tanggal    DateTime      @db.Date
  shiftId    String?       @map("shift_id") @db.Uuid
  jamMasuk   DateTime?     @map("jam_masuk") @db.Time(0)
  jamKeluar  DateTime?     @map("jam_keluar") @db.Time(0)
  status     StatusAbsensi @default(Hadir)
  keterangan String?

  pegawai Pegawai @relation(fields: [pegawaiId], references: [id], onDelete: Cascade)

  @@unique([pegawaiId, tanggal])
  @@index([tanggal])
  @@map("absensi")
  @@schema("master")
}

// ── Kontak darurat pegawai (1:N) ──────────────────────────────────────────────

model PegawaiKontakDarurat {
  id        String  @id @default(uuid(7)) @db.Uuid
  pegawaiId String  @map("pegawai_id") @db.Uuid
  nama      String
  hubungan  String
  noHp      String  @map("no_hp")
  alamat    String?

  pegawai Pegawai @relation(fields: [pegawaiId], references: [id], onDelete: Cascade)

  @@index([pegawaiId])
  @@map("pegawai_kontak_darurat")
  @@schema("master")
}
