// ════════════════════════════════════════════════════════════════════════════
//  MODUL: AUTH  (Postgres schema "auth")  ·  Acuan: docs/BACKEND-AUTH.md
//  Identitas · multi-role RBAC · ABAC unit-scope · sesi hybrid (refresh token).
//  Access JWT = stateless (tak ada tabel) · revocation = Redis (jti + tokenVersion).
//
//  Konvensi (FLOWS §9): PK uuid v7 @db.Uuid · timestamptz UTC · citext (CI) ·
//  camelCase model + @@map snake_case · soft-delete.
//  Migration SQL manual: RLS · partial index (deleted_at/revoked_at IS NULL) · CHECK.
// ════════════════════════════════════════════════════════════════════════════

// ── Enums (Postgres native enum) ──────────────────────────────────────────────

enum UserStatus {
  Active
  Suspended
  Locked

  @@schema("auth")
}

/// Aksi CRUD granular (selaras frontend rbacShared.CrudAction).
enum CrudAction {
  read
  create
  update
  delete
  export

  @@schema("auth")
}

// ── User ──────────────────────────────────────────────────────────────────--

/// Akun pengguna sistem. Kredensial argon2id. PII di-handle app-level (encrypt + scrub).
model User {
  id String @id @default(uuid(7)) @db.Uuid

  /// citext → uniqueness case-insensitive di DB (bukan ditambal app). Login by username/NIP.
  /// Identitas tampil (nama/email/noHp/foto/nip) TIDAK diduplikasi di sini —
  /// single source of truth = sdm.Pegawai (baca via relasi `pegawai`).
  /// Tampilan cepat (header/sesi) → JWT claim saat login, bukan kolom. Audit → snapshot di baris audit.
  username     String @unique @db.Citext
  passwordHash String @map("password_hash")

  status             UserStatus @default(Active)
  /// Bump = revoke SEMUA sesi user (dicek per-request via Redis). BACKEND-AUTH §3.
  tokenVersion       Int        @default(0) @map("token_version")
  mustChangePassword Boolean    @default(true) @map("must_change_password")

  // MFA — field disiapkan (forward-compat); enforcement DITUNDA pasca-MVP.
  mfaEnabled Boolean @default(false) @map("mfa_enabled")
  /// TOTP secret — WAJIB encrypted at-rest (app-level, Secret Manager).
  mfaSecret  String? @map("mfa_secret")

  // Brute-force lockout (BACKEND-AUTH §3/§7).
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until") @db.Timestamptz(3)
  lastLoginAt      DateTime? @map("last_login_at") @db.Timestamptz(3)
  lastLoginIp      String?   @map("last_login_ip")

  /// WAJIB: setiap akun harus pegawai terdaftar (zero orphan account).
  /// Provisioning: validasi NIK → resolve pegawai → set pegawaiId. Dokter? = pegawai.practitionerId.
  pegawaiId String  @unique @map("pegawai_id") @db.Uuid
  pegawai   Pegawai @relation(fields: [pegawaiId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)

  roles         UserRole[]
  unitScopes    UserUnitScope[]
  refreshTokens RefreshToken[]

  @@index([status])
  @@map("users")
  @@schema("auth")
}

// ── Role / Permission (RBAC matrix = master data, dikelola Mapping Hub) ───────

/// 9 role seed: Admin·Dokter·Perawat·Apoteker·Radiografer·SpPK·SpRad·Kasir·Registrasi.
model Role {
  id         String  @id @default(uuid(7)) @db.Uuid
  key        String  @unique // mis. "Dokter"
  nama       String
  deskripsi  String?
  /// least-privilege (BACKEND-AUTH §2.3): false=global (bypass unit-scope),
  /// true=unit-scoped (wajib ≥1 UserUnitScope, kosong=tolak data klinis).
  unitScoped Boolean @default(false) @map("unit_scoped")
  isActive   Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
  @@schema("auth")
}

/// Join M:N user↔role (multi-role TERKUNCI). Permission efektif = UNION lintas role.
model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(3)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
  @@schema("auth")
}

/// Permission ATOMIK per (resource × action) — model relasional (lebih ternormalisasi
/// daripada actions[] array; selaras referensi usr_permission). `resource` = leaf key
/// frontend (mis. "clinical.cppt"); `action` = CrudAction. ~100 baris (28 leaf × aksi).
model Permission {
  id       String     @id @default(uuid(7)) @db.Uuid
  resource String // leaf key, mis. "clinical.cppt"
  action   CrudAction
  /// kode unik gabungan, mis. "clinical.cppt:update".
  kode     String     @unique
  nama     String
  modul    String // grup tampilan, mis. "clinical"

  roles RolePermission[]

  @@unique([resource, action])
  @@index([modul])
  @@map("permissions")
  @@schema("auth")
}

/// Join murni role↔permission = RBACMap. Editable di Mapping Hub (domain Master).
model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
  @@schema("auth")
}

// ── ABAC: unit-scope ──────────────────────────────────────────────────────---

/// Unit yang boleh diakses user (mis. Perawat hanya ICU). Sumber: Pengguna.unitAssignment.
/// unitId → master ruangan (cross-schema, @db.Uuid sampai modul master siap).
model UserUnitScope {
  userId String @map("user_id") @db.Uuid
  unitId String @map("unit_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, unitId])
  @@index([unitId])
  @@map("user_unit_scopes")
  @@schema("auth")
}

// ── Sesi hybrid: Refresh token (rotating + reuse detection) ───────────────────
//  Access token = JWT pendek (30m) STATELESS — tidak disimpan. Revocation via Redis.
//  Refresh token = 3h (idle, sliding) — disimpan HASH-nya, rotasi tiap pakai.

model RefreshToken {
  id String @id @default(uuid(7)) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// SHA-256 hash dari refresh token (JANGAN simpan plaintext).
  tokenHash String @unique @map("token_hash")
  /// Grup rotasi — reuse detection (cabut seluruh family bila token revoked dipakai lagi).
  familyId  String @map("family_id") @db.Uuid

  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(3)
  /// Refresh penerus saat rotasi (audit trail rantai sesi).
  replacedById String?   @map("replaced_by_id") @db.Uuid

  ip         String?
  userAgent  String?   @map("user_agent")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(3)

  @@index([userId, revokedAt])
  @@index([familyId])
  @@map("refresh_tokens")
  @@schema("auth")
}
